package gala_tui

import (
    . "martianoff/gala/go_interop"
    . "martianoff/gala/test"
)

// ============================================================================
// Tests for SGR mouse parsing + InputEvent dispatch helpers.
//
// Test vectors are synthesized as raw byte sequences so the parser is exercised
// exactly the same way stdin feeds it at runtime.
// ============================================================================

// Build an SGR mouse packet: ESC [ < btn ; x ; y M|m
func mousePacket(btn int, x int, y int, press bool) []byte {
    var bs = SliceEmpty[byte]()
    bs = append(bs, byte(0x1B), byte('['), byte('<'))
    for _, c := range intToDecimalRunes(btn) { bs = append(bs, byte(c)) }
    bs = append(bs, byte(';'))
    for _, c := range intToDecimalRunes(x) { bs = append(bs, byte(c)) }
    bs = append(bs, byte(';'))
    for _, c := range intToDecimalRunes(y) { bs = append(bs, byte(c)) }
    if press {
        bs = append(bs, byte('M'))
    } else {
        bs = append(bs, byte('m'))
    }
    return bs
}

func intToDecimalRunes(n int) []rune {
    if n == 0 {
        var zero = SliceEmpty[rune]()
        return append(zero, rune('0'))
    }
    var neg = false
    var v = n
    if v < 0 {
        neg = true
        v = -v
    }
    var rev = SliceEmpty[rune]()
    for v > 0 {
        val d = v % 10
        rev = append(rev, rune('0' + d))
        v = v / 10
    }
    var out = SliceEmpty[rune]()
    if neg {
        out = append(out, rune('-'))
    }
    var i = len(rev) - 1
    for i >= 0 {
        out = append(out, rev[i])
        i = i - 1
    }
    return out
}

// ----------------------------------------------------------------------------
// Mouse packet parsing
// ----------------------------------------------------------------------------

func TestParseInputMouseLeftPress(t T) T {
    val buf = mousePacket(0, 5, 7, true)
    val (ev, n) = ParseInput(buf)
    val isMouse = ev match {
        case MouseInput(_) => true
        case _             => false
    }
    val t1 = IsTrue(t, isMouse)
    return IsTrue(t1, n == len(buf))
}

func TestParseInputMouseCoordsAreZeroIndexed(t T) T {
    // Mouse packet at SGR-1-indexed (5, 7) → we expose (4, 6).
    val buf = mousePacket(0, 5, 7, true)
    val (ev, _) = ParseInput(buf)
    val (x, y) = ev match {
        case MouseInput(m) => (m.X, m.Y)
        case _             => (-1, -1)
    }
    val t1 = Eq(t, x, 4)
    return Eq(t1, y, 6)
}

func TestParseInputMouseReleaseFlag(t T) T {
    val buf = mousePacket(0, 1, 1, false)
    val (ev, _) = ParseInput(buf)
    val released = ev match {
        case MouseInput(m) => !m.Pressed
        case _             => false
    }
    return IsTrue(t, released)
}

func TestParseInputMouseButtonMiddle(t T) T {
    val buf = mousePacket(1, 2, 3, true)
    val (ev, _) = ParseInput(buf)
    val isMid = ev match {
        case MouseInput(m) => mouseBtnIs(m.Btn, "middle")
        case _             => false
    }
    return IsTrue(t, isMid)
}

func TestParseInputMouseButtonRight(t T) T {
    val buf = mousePacket(2, 2, 3, true)
    val (ev, _) = ParseInput(buf)
    val isR = ev match {
        case MouseInput(m) => mouseBtnIs(m.Btn, "right")
        case _             => false
    }
    return IsTrue(t, isR)
}

func TestParseInputMouseScrollUp(t T) T {
    val buf = mousePacket(64, 10, 10, true)
    val (ev, _) = ParseInput(buf)
    val isUp = ev match {
        case MouseInput(m) => mouseBtnIs(m.Btn, "scroll-up")
        case _             => false
    }
    return IsTrue(t, isUp)
}

func TestParseInputMouseScrollDown(t T) T {
    val buf = mousePacket(65, 10, 10, true)
    val (ev, _) = ParseInput(buf)
    val isDn = ev match {
        case MouseInput(m) => mouseBtnIs(m.Btn, "scroll-down")
        case _             => false
    }
    return IsTrue(t, isDn)
}

func TestParseInputKeyFallthrough(t T) T {
    // Plain ASCII 'a' should flow through as KeyInput.
    var bs = SliceEmpty[byte]()
    bs = append(bs, byte('a'))
    val (ev, n) = ParseInput(bs)
    val isKey = ev match {
        case KeyInput(_) => true
        case _           => false
    }
    val t1 = IsTrue(t, isKey)
    return Eq(t1, n, 1)
}

func TestParseInputIncompleteMouseReturnsZeroConsumed(t T) T {
    // Only the prefix ESC [ < with no terminator — parser should request more.
    var bs = SliceEmpty[byte]()
    bs = append(bs, byte(0x1B), byte('['), byte('<'), byte('0'))
    val (_, n) = ParseInput(bs)
    return Eq(t, n, 0)
}

// Motion-while-held: SGR button code 32 (left button + motion bit 5).
// Surfaces as Motion=true and the same Btn as the originating press
// (left), so consumers can implement drag tracking by remembering
// the press's button and reading subsequent motion events.
func TestParseInputMouseLeftDragMotion(t T) T {
    val buf = mousePacket(32, 12, 7, true)
    val (ev, _) = ParseInput(buf)
    return ev match {
        case MouseInput(m) => {
            val t1 = IsTrue(t, m.Motion)
            val t2 = IsTrue(t1, m.Pressed)
            val t3 = IsTrue(t2, mouseBtnIs(m.Btn, "left"))
            val t4 = Eq(t3, m.X, 11)
            return Eq(t4, m.Y, 6)
        }
        case _ => IsTrue(t, false)
    }
}

// A plain left press (code 0, no motion bit) MUST surface Motion=false.
// Guards against a regression where the bit-extraction logic could
// flip the flag for non-motion events.
func TestParseInputMouseLeftPressMotionFalse(t T) T {
    val buf = mousePacket(0, 5, 5, true)
    val (ev, _) = ParseInput(buf)
    return ev match {
        case MouseInput(m) => IsFalse(t, m.Motion)
        case _             => IsTrue(t, false)
    }
}

// Right-button drag: code = 2 (right) | 32 (motion) = 34. Btn must
// resolve to MouseRight and Motion must be true.
func TestParseInputMouseRightDragMotion(t T) T {
    val buf = mousePacket(34, 8, 4, true)
    val (ev, _) = ParseInput(buf)
    return ev match {
        case MouseInput(m) => {
            val t1 = IsTrue(t, m.Motion)
            return IsTrue(t1, mouseBtnIs(m.Btn, "right"))
        }
        case _ => IsTrue(t, false)
    }
}

// ansiMouseOn must include the ?1002h button-event tracking sequence
// alongside ?1000h and ?1006h. Without ?1002h the terminal never
// emits motion-while-held packets and drag UX in consumers silently
// dies.
func TestAnsiMouseOnIncludesButtonEventTracking(t T) T {
    val on = ansiMouseOn()
    return IsTrue(t, contains(on, "?1002h"))
}

// And ansiMouseOff must disable it on shutdown — orphaned ?1002 mode
// would leak motion events into whatever shell takes over the
// terminal after the app exits.
func TestAnsiMouseOffDisablesButtonEventTracking(t T) T {
    val off = ansiMouseOff()
    return IsTrue(t, contains(off, "?1002l"))
}

// contains is a tiny strings.Contains shim — pulling in the strings
// import for one call would inflate the test file's imports.
func contains(haystack string, needle string) bool {
    val hLen = len(haystack)
    val nLen = len(needle)
    if nLen == 0 { return true }
    if nLen > hLen { return false }
    var i = 0
    val limit = hLen - nLen
    for i <= limit {
        var j = 0
        var match = true
        for j < nLen {
            if haystack[i+j] != needle[j] { match = false; j = nLen }
            else { j = j + 1 }
        }
        if match { return true }
        i = i + 1
    }
    return false
}

// ----------------------------------------------------------------------------
// MouseButton tag helper — isolates the sealed match so callers don't
// duplicate the boilerplate.
// ----------------------------------------------------------------------------

func mouseBtnIs(b MouseButton, name string) bool {
    return b match {
        case MouseLeft()        => name == "left"
        case MouseMiddle()      => name == "middle"
        case MouseRight()       => name == "right"
        case MouseScrollUp()    => name == "scroll-up"
        case MouseScrollDown()  => name == "scroll-down"
        case MouseButtonNone()  => name == "none"
    }
}
