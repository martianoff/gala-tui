package state

import (
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/test"
)

// ============================================================================
// Direct tests for FocusManager.Route / FocusManager.When + OnPane.
//
// Pins down: matching pane wins, fallback when nothing matches, first-case-
// wins on duplicate panes, thunk laziness (only the matching handler runs),
// empty-cases + wrong-pane fallback paths.
// ============================================================================

sealed type RouterTestResult {
    case RTSidebar()
    case RTTable()
    case RTDrawer()
    case RTFallback()
}

func ringSidebarTable() FocusManager =
    NewFocusManager(ArrayOf[string]("sidebar", "table", "drawer"))

func tableFocused() FocusManager = ringSidebarTable().Next()
func drawerFocused() FocusManager = ringSidebarTable().Next().Next()

// ----------------------------------------------------------------------------
// Route
// ----------------------------------------------------------------------------

func TestRouteFiresMatchingCase(t T) T {
    val got = tableFocused().Route[RouterTestResult](
        ArrayOf[FocusedCase[RouterTestResult]](
            OnPane[RouterTestResult]("sidebar", () => RTSidebar()),
            OnPane[RouterTestResult]("table",   () => RTTable()),
        ),
        RTFallback(),
    )
    val isTable = got match {
        case RTTable() => true
        case _         => false
    }
    return IsTrue(t, isTable)
}

func TestRouteFallbackOnUnregisteredPane(t T) T {
    // drawer is focused, but no case for it — fallback fires.
    val got = drawerFocused().Route[RouterTestResult](
        ArrayOf[FocusedCase[RouterTestResult]](
            OnPane[RouterTestResult]("sidebar", () => RTSidebar()),
            OnPane[RouterTestResult]("table",   () => RTTable()),
        ),
        RTFallback(),
    )
    val isFallback = got match {
        case RTFallback() => true
        case _            => false
    }
    return IsTrue(t, isFallback)
}

func TestRouteFallbackWhenCasesEmpty(t T) T {
    val got = ringSidebarTable().Route[RouterTestResult](
        EmptyArray[FocusedCase[RouterTestResult]](),
        RTFallback(),
    )
    val isFallback = got match {
        case RTFallback() => true
        case _            => false
    }
    return IsTrue(t, isFallback)
}

// First-match-wins: if two cases name the same pane, the earlier one fires.
func TestRouteFirstMatchingCaseWins(t T) T {
    val got = ringSidebarTable().Route[RouterTestResult](
        ArrayOf[FocusedCase[RouterTestResult]](
            OnPane[RouterTestResult]("sidebar", () => RTSidebar()),
            OnPane[RouterTestResult]("sidebar", () => RTTable()),
        ),
        RTFallback(),
    )
    val isFirst = got match {
        case RTSidebar() => true
        case _           => false
    }
    return IsTrue(t, isFirst)
}

// Thunk laziness — non-matching handlers must not run. Verified via a
// captured counter that increments inside each handler. After Route
// returns, only the matching pane's counter should have moved.
func TestRouteNonMatchingHandlersDontRun(t T) T {
    var sidebarCalls = 0
    var tableCalls = 0
    val _ = tableFocused().Route[int](
        ArrayOf[FocusedCase[int]](
            OnPane[int]("sidebar",
                () => { sidebarCalls = sidebarCalls + 1; 1 }),
            OnPane[int]("table",
                () => { tableCalls = tableCalls + 1; 2 }),
        ),
        0,
    )
    val t1 = Eq(t, sidebarCalls, 0)
    return Eq(t1, tableCalls, 1)
}

// ----------------------------------------------------------------------------
// When
// ----------------------------------------------------------------------------

func TestWhenFiresAction(t T) T {
    val got = tableFocused().When[RouterTestResult]("table",
        () => RTTable(),
        RTFallback(),
    )
    val isTable = got match {
        case RTTable() => true
        case _         => false
    }
    return IsTrue(t, isTable)
}

func TestWhenFallsBackWhenWrongPane(t T) T {
    val got = tableFocused().When[RouterTestResult]("sidebar",
        () => RTSidebar(),
        RTFallback(),
    )
    val isFallback = got match {
        case RTFallback() => true
        case _            => false
    }
    return IsTrue(t, isFallback)
}

func TestWhenActionDoesNotRunOnMiss(t T) T {
    var calls = 0
    val _ = ringSidebarTable().When[int]("table",
        () => { calls = calls + 1; 99 },
        0,
    )
    return Eq(t, calls, 0)
}

// ----------------------------------------------------------------------------
// OnPane shorthand — verifies the constructor produces the same struct as
// a hand-built FocusedCase.
// ----------------------------------------------------------------------------

func TestOnPaneShorthandMatchesHandBuilt(t T) T {
    val byShort = OnPane[int]("table", () => 42)
    val byLong  = FocusedCase[int](Pane = "table", Handler = () => 42)
    val t1 = Eq(t, byShort.Pane, byLong.Pane)
    return Eq(t1, byShort.Handler(), byLong.Handler())
}
