package gala_tui

import (
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/test"
    . "martianoff/gala/time_utils"
)

// ============================================================================
// ToastQueue + StatusBar tests.
// ============================================================================

func epoch() Instant = FromUnixNanos(int64(0))

// ----------------------------------------------------------------------------
// ToastQueue
// ----------------------------------------------------------------------------

func TestToastQueueStartsEmpty(t T) T {
    return IsTrue(t, NewToastQueue(5).IsEmpty())
}

func TestToastQueuePushGrowsUntilCap(t T) T {
    var q = NewToastQueue(3)
    q = q.PushInfo("a", epoch(), Seconds(int64(1)))
    q = q.PushInfo("b", epoch(), Seconds(int64(1)))
    q = q.PushInfo("c", epoch(), Seconds(int64(1)))
    return Eq(t, q.Length(), 3)
}

func TestToastQueueDropsOldestBeyondCap(t T) T {
    var q = NewToastQueue(2)
    q = q.PushInfo("a", epoch(), Seconds(int64(1)))
    q = q.PushInfo("b", epoch(), Seconds(int64(1)))
    q = q.PushInfo("c", epoch(), Seconds(int64(1)))
    val t1 = Eq(t, q.Length(), 2)
    return Eq(t1, q.Items.Get(0).Message, "b")
}

func TestToastQueuePruneRemovesExpired(t T) T {
    var q = NewToastQueue(10)
    q = q.PushInfo("short", epoch(), Milliseconds(int64(100)))
    q = q.PushInfo("long",  epoch(), Seconds(int64(60)))
    // Advance the clock 1 second past epoch — "short" should be gone.
    val now = epoch().Plus(Seconds(int64(1)))
    val pruned = q.Prune(now)
    val t1 = Eq(t, pruned.Length(), 1)
    return Eq(t1, pruned.Items.Get(0).Message, "long")
}

func TestToastQueuePruneAtExpirationBoundaryDrops(t T) T {
    var q = NewToastQueue(10)
    val ttl = Milliseconds(int64(500))
    q = q.PushInfo("x", epoch(), ttl)
    // At exactly expiration, toast expires (ExpiresAt.Since(now) == 0 → drop).
    val atExpiry = epoch().Plus(ttl)
    val pruned = q.Prune(atExpiry)
    return IsTrue(t, pruned.IsEmpty())
}

func TestToastPushLevelHelpers(t T) T {
    var q = NewToastQueue(10)
    q = q.PushInfo("i", epoch(), Seconds(int64(1)))
    q = q.PushSuccess("s", epoch(), Seconds(int64(1)))
    q = q.PushWarn("w", epoch(), Seconds(int64(1)))
    q = q.PushError("e", epoch(), Seconds(int64(1)))
    return Eq(t, q.Length(), 4)
}

// ----------------------------------------------------------------------------
// ToastView
// ----------------------------------------------------------------------------

func TestToastViewEmptyRendersNothing(t T) T {
    val q = NewToastQueue(5)
    val w = ToastView(q)
    // Empty widget → intrinsic width 0.
    return Eq(t, defaultRenderWidth(w), 0)
}

func TestToastViewShowsMostRecent(t T) T {
    var q = NewToastQueue(10)
    q = q.PushInfo("older", epoch(), Seconds(int64(1)))
    q = q.PushInfo("newer", epoch(), Seconds(int64(1)))
    var buf = NewBuffer(20, 1)
    RenderTo(ToastView(q), Rect(X = 0, Y = 0, Width = 20, Height = 1), buf)
    val row = BufferText(buf, 0)
    return IsTrue(t, toastRowContains(row, "newer"))
}

func TestToastViewErrorIsRedBackground(t T) T {
    var q = NewToastQueue(5)
    q = q.PushError("oops", epoch(), Seconds(int64(1)))
    var buf = NewBuffer(20, 1)
    RenderTo(ToastView(q), Rect(X = 0, Y = 0, Width = 20, Height = 1), buf)
    return IsTrue(t, ColorEq(buf.StyleAt(0, 0).Bg, BrightRed()))
}

func TestToastStackViewRendersAllToasts(t T) T {
    var q = NewToastQueue(5)
    q = q.PushInfo("first",  epoch(), Seconds(int64(1)))
    q = q.PushInfo("second", epoch(), Seconds(int64(1)))
    q = q.PushInfo("third",  epoch(), Seconds(int64(1)))
    var buf = NewBuffer(20, 3)
    RenderTo(ToastStackView(q), Rect(X = 0, Y = 0, Width = 20, Height = 3), buf)
    val t1 = IsTrue(t, toastRowContains(BufferText(buf, 0), "first"))
    val t2 = IsTrue(t1, toastRowContains(BufferText(buf, 1), "second"))
    return IsTrue(t2, toastRowContains(BufferText(buf, 2), "third"))
}

// ----------------------------------------------------------------------------
// StatusBar
// ----------------------------------------------------------------------------

func TestStatusBarRendersThreeSlots(t T) T {
    val bar = NewStatusBar(
        Text(" focus: sidebar "),
        Text(" doc.gala "),
        Text(" 12:34 "),
    )
    var buf = NewBuffer(60, 1)
    RenderTo(StatusBarView(bar), Rect(X = 0, Y = 0, Width = 60, Height = 1), buf)
    val row = BufferText(buf, 0)
    val t1 = IsTrue(t, toastRowContains(row, "focus: sidebar"))
    val t2 = IsTrue(t1, toastRowContains(row, "doc.gala"))
    return IsTrue(t2, toastRowContains(row, "12:34"))
}

func TestStatusBarBackgroundStyled(t T) T {
    val bar = NewStatusBar(Text("l"), Text("c"), Text("r"))
    var buf = NewBuffer(20, 1)
    RenderTo(StatusBarView(bar), Rect(X = 0, Y = 0, Width = 20, Height = 1), buf)
    // Whole row has the cyan background.
    return IsTrue(t, ColorEq(buf.StyleAt(10, 0).Bg, BrightCyan()))
}

// ----------------------------------------------------------------------------
// Helpers.
// ----------------------------------------------------------------------------

func toastRowContains(hay string, needle string) bool {
    val h = toastRuneArr(hay)
    val n = toastRuneArr(needle)
    val hn = h.Length()
    val nn = n.Length()
    if nn == 0 { return true }
    if nn > hn { return false }
    var i = 0
    for i <= hn - nn {
        var j = 0
        var ok = true
        for j < nn {
            if h.Get(i + j) != n.Get(j) {
                ok = false
                j = nn
            } else {
                j = j + 1
            }
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

func toastRuneArr(s string) Array[rune] {
    var acc = EmptyArray[rune]()
    for _, c := range s {
        acc = acc.Append(c)
    }
    return acc
}
