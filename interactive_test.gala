package gala_tui

import (
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/test"
)

// ============================================================================
// List widget
// ============================================================================

func TestListSelectionHighlight(t T) T {
    var buf = NewBuffer(6, 3)
    val w = SelectListOf(ArrayOf[string]("apple", "banana", "cherry"), 1)
    RenderTo(w, Rect(X = 0, Y = 0, Width = 6, Height = 3), buf)
    val t1 = Eq(t, BufferText(buf, 0), "apple ")
    val t2 = Eq(t1, BufferText(buf, 1), "banana")   // selected row filled to width
    // Selected row style should be reverse.
    return IsTrue(t2, buf.StyleAt(0, 1).Reverse)
}

func TestListHandlesEmpty(t T) T {
    var buf = NewBuffer(5, 2)
    val w = SelectListOf(EmptyArray[string](), 0)
    RenderTo(w, Rect(X = 0, Y = 0, Width = 5, Height = 2), buf)
    // Nothing should crash; buffer stays blank.
    return Eq(t, BufferText(buf, 0), "     ")
}

func TestListScrollsToShowSelected(t T) T {
    // 5 items, viewport height 2, selected = 4. Viewport must slide to show
    // items 3 and 4 (offset = 3).
    var buf = NewBuffer(4, 2)
    val w = SelectListOf(ArrayOf[string]("a", "b", "c", "d", "e"), 4)
    RenderTo(w, Rect(X = 0, Y = 0, Width = 4, Height = 2), buf)
    val t1 = Eq(t, BufferText(buf, 0), "d   ")
    return Eq(t1, BufferText(buf, 1), "e   ")
}

func TestListViewportOffsetBasic(t T) T {
    val t1 = Eq(t, listViewportOffset(5, 0, 3), 0)
    val t2 = Eq(t1, listViewportOffset(5, 2, 3), 0)
    val t3 = Eq(t2, listViewportOffset(5, 3, 3), 1)
    return Eq(t3, listViewportOffset(5, 4, 3), 2)
}

// ============================================================================
// Input widget
// ============================================================================

func TestInputShowsPlaceholderWhenEmpty(t T) T {
    var buf = NewBuffer(12, 1)
    val w = Input("", 0, "type here")
    RenderTo(w, Rect(X = 0, Y = 0, Width = 12, Height = 1), buf)
    val t1 = Eq(t, BufferText(buf, 0), "type here   ")
    // Placeholder rendered with dim style.
    return IsTrue(t1, buf.StyleAt(0, 0).Dim)
}

func TestInputShowsValueAndCursor(t T) T {
    var buf = NewBuffer(10, 1)
    val w = Input("hello", 3, "")
    RenderTo(w, Rect(X = 0, Y = 0, Width = 10, Height = 1), buf)
    val t1 = Eq(t, BufferText(buf, 0), "hello     ")
    // Cursor at column 3 → that cell should be reversed.
    return IsTrue(t1, buf.StyleAt(3, 0).Reverse)
}

// ============================================================================
// Progress / Gauge
// ============================================================================

func TestProgressBarHalf(t T) T {
    var buf = NewBuffer(10, 1)
    val w = Progress(50)
    RenderTo(w, Rect(X = 0, Y = 0, Width = 10, Height = 1), buf)
    // 10-width bar, 50%: "[████░░░░]" — 4 filled + 4 empty between brackets.
    return Eq(t, BufferText(buf, 0), "[████░░░░]")
}

func TestProgressBarFull(t T) T {
    var buf = NewBuffer(8, 1)
    val w = Progress(100)
    RenderTo(w, Rect(X = 0, Y = 0, Width = 8, Height = 1), buf)
    return Eq(t, BufferText(buf, 0), "[██████]")
}

func TestProgressBarEmpty(t T) T {
    var buf = NewBuffer(8, 1)
    val w = Progress(0)
    RenderTo(w, Rect(X = 0, Y = 0, Width = 8, Height = 1), buf)
    return Eq(t, BufferText(buf, 0), "[░░░░░░]")
}

func TestProgressClampsOverflow(t T) T {
    var buf = NewBuffer(8, 1)
    val w = Progress(250)   // out of range
    RenderTo(w, Rect(X = 0, Y = 0, Width = 8, Height = 1), buf)
    // Clamped to 100% → all inner cells filled.
    return Eq(t, BufferText(buf, 0), "[██████]")
}

func TestGaugeFullCells(t T) T {
    var buf = NewBuffer(4, 1)
    val w = Gauge(50)
    RenderTo(w, Rect(X = 0, Y = 0, Width = 4, Height = 1), buf)
    // 4 cells, 50% → 2 full + 2 empty.
    return Eq(t, BufferText(buf, 0), "██  ")
}

// ============================================================================
// Spinner
// ============================================================================

func TestSpinnerWrapsFrameIndex(t T) T {
    // Pipe spinner has 4 frames; frame=5 should wrap to frame 1.
    val t1 = Eq(t, SpinnerGlyph(PipeSpinner(), 0), '|')
    val t2 = Eq(t1, SpinnerGlyph(PipeSpinner(), 1), '/')
    val t3 = Eq(t2, SpinnerGlyph(PipeSpinner(), 4), '|')   // wrap
    return Eq(t3, SpinnerGlyph(PipeSpinner(), 5), '/')
}

func TestSpinnerRendersCell(t T) T {
    var buf = NewBuffer(3, 1)
    val w = Spinner(PipeSpinner(), 2)  // '-'
    RenderTo(w, Rect(X = 0, Y = 0, Width = 3, Height = 1), buf)
    return Eq(t, BufferText(buf, 0), "-  ")
}

// ============================================================================
// Button
// ============================================================================

func TestButtonRendersLabel(t T) T {
    var buf = NewBuffer(10, 1)
    val w = Button("OK", false)
    RenderTo(w, Rect(X = 0, Y = 0, Width = 10, Height = 1), buf)
    // "[ OK ]" = 6 chars + 4 blanks = 10.
    return Eq(t, BufferText(buf, 0), "[ OK ]    ")
}

func TestFocusedButtonIsReversed(t T) T {
    var buf = NewBuffer(10, 1)
    val w = Button("OK", true)
    RenderTo(w, Rect(X = 0, Y = 0, Width = 10, Height = 1), buf)
    val t1 = Eq(t, BufferText(buf, 0), "[ OK ]    ")
    return IsTrue(t1, buf.StyleAt(0, 0).Reverse)
}
