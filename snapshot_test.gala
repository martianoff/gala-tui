package gala_tui

import (
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/test"
)

// ============================================================================
// Snapshot helper tests.
// ============================================================================

func TestSnapshotReturnsPlainText(t T) T {
    val out = Snapshot(Text("hi"), 5, 1)
    return Eq(t, out, "hi   ")
}

func TestSnapshotIncludesRowSeparators(t T) T {
    val widget = Column(
        ArrayOf[LayoutChild](
            Fixed(1, Text("aa")),
            Fixed(1, Text("bb")),
        ))
    val out = Snapshot(widget, 3, 2)
    return Eq(t, out, "aa \nbb ")
}

func TestSnapshotLinesSplitsByRow(t T) T {
    val widget = Column(
        ArrayOf[LayoutChild](
            Fixed(1, Text("alpha")),
            Fixed(1, Text("beta")),
        ))
    val rows = SnapshotLines(widget, 5, 2)
    val t1 = Eq(t, rows.Length(), 2)
    val t2 = Eq(t1, rows.Get(0), "alpha")
    return Eq(t2, rows.Get(1), "beta ")
}

func TestSnapshotStyledEmitsAnsiCodes(t T) T {
    val out = SnapshotStyled(TextStyled("hi", DefaultStyle().WithBold()), 3, 1)
    // ToSgr for Bold is "\x1b[1m" — should appear somewhere.
    return IsTrue(t, containsBoldSgr(out))
}

func TestSnapshotDiffMatchingIsNone(t T) T {
    val diff = SnapshotDiff("abc\ndef", "abc\ndef")
    return IsFalse(t, diff.IsDefined())
}

func TestSnapshotDiffDifferentReturnsSome(t T) T {
    val diff = SnapshotDiff("abc\ndef", "abc\nXYZ")
    return IsTrue(t, diff.IsDefined())
}

func TestSnapshotsEqualMatchesIdentical(t T) T {
    return IsTrue(t, SnapshotsEqual("abc", "abc"))
}

// ----------------------------------------------------------------------------
// Bigger integration: snapshot an entire composition end-to-end.
// ----------------------------------------------------------------------------

func TestSnapshotBorderedText(t T) T {
    val widget = Text("hi").Padded(0).Bordered()
    val out = Snapshot(widget, 4, 3)
    return Eq(t, out, "┌──┐\n│hi│\n└──┘")
}

func TestSnapshotComposedDashboardLayout(t T) T {
    val header = TextStyled("DASHBOARD", DefaultStyle().WithBold())
    val footer = Text("press q to quit")
    val widget = Column(ArrayOf[LayoutChild](
        Fixed(1, header),
        Flex(1, Text("body")),
        Fixed(1, footer),
    ))
    val rows = SnapshotLines(widget, 20, 4)
    val t1 = Eq(t, rows.Length(), 4)
    val t2 = IsTrue(t1, snapRowHas(rows.Get(0), "DASHBOARD"))
    val t3 = IsTrue(t2, snapRowHas(rows.Get(1), "body"))
    return IsTrue(t3, snapRowHas(rows.Get(3), "press q to quit"))
}

// ----------------------------------------------------------------------------
// Helpers.
// ----------------------------------------------------------------------------

func containsBoldSgr(s string) bool {
    // Look for literal ESC '[' '1' 'm' (ESC = 0x1B)
    val esc = rune(0x1B)
    var prev1 = ' '
    var prev2 = ' '
    var prev3 = ' '
    for _, c := range s {
        if prev3 == esc && prev2 == '[' && prev1 == '1' && c == 'm' {
            return true
        }
        prev3 = prev2
        prev2 = prev1
        prev1 = c
    }
    return false
}

func snapRowHas(hay string, needle string) bool {
    val h = snapRunes(hay)
    val n = snapRunes(needle)
    val hn = h.Length()
    val nn = n.Length()
    if nn == 0 { return true }
    if nn > hn { return false }
    var i = 0
    for i <= hn - nn {
        var j = 0
        var ok = true
        for j < nn {
            if h.Get(i + j) != n.Get(j) {
                ok = false
                j = nn
            } else {
                j = j + 1
            }
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

func snapRunes(s string) Array[rune] {
    var acc = EmptyArray[rune]()
    for _, c := range s {
        acc = acc.Append(c)
    }
    return acc
}
