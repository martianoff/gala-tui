package gala_tui

import (
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/test"
)

// ============================================================================
// Constraint-solver unit tests — the heart of every Row/Column layout.
// ============================================================================

func TestSolveEmptyConstraints(t T) T {
    val sizes = Solve(100, EmptyArray[Constraint]())
    return Eq(t, sizes.Length(), 0)
}

func TestSolveAllLength(t T) T {
    val sizes = Solve(10, ArrayOf[Constraint](Length(3), Length(4), Length(2)))
    val t1 = Eq(t, sizes.Get(0), 3)
    val t2 = Eq(t1, sizes.Get(1), 4)
    return Eq(t2, sizes.Get(2), 2)
}

func TestSolveSingleFill(t T) T {
    val sizes = Solve(10, ArrayOf[Constraint](Fill(1)))
    return Eq(t, sizes.Get(0), 10)
}

func TestSolveLengthPlusFill(t T) T {
    val sizes = Solve(10, ArrayOf[Constraint](Length(3), Fill(1), Length(2)))
    val t1 = Eq(t, sizes.Get(0), 3)
    val t2 = Eq(t1, sizes.Get(1), 5)
    return Eq(t2, sizes.Get(2), 2)
}

func TestSolveWeightedFills(t T) T {
    val sizes = Solve(9, ArrayOf[Constraint](Fill(2), Fill(1)))
    val t1 = Eq(t, sizes.Get(0), 6)
    return Eq(t1, sizes.Get(1), 3)
}

func TestSolveFillRemainderGoesToLast(t T) T {
    val sizes = Solve(10, ArrayOf[Constraint](Fill(1), Fill(1), Fill(1)))
    val t1 = Eq(t, sizes.Get(0), 3)
    val t2 = Eq(t1, sizes.Get(1), 3)
    return Eq(t2, sizes.Get(2), 4)
}

func TestSolvePercent(t T) T {
    val sizes = Solve(100, ArrayOf[Constraint](Percent(25), Percent(25), Percent(50)))
    val t1 = Eq(t, sizes.Get(0), 25)
    val t2 = Eq(t1, sizes.Get(1), 25)
    return Eq(t2, sizes.Get(2), 50)
}

func TestSolveOverflowIsClipped(t T) T {
    val sizes = Solve(100, ArrayOf[Constraint](Length(50), Length(40), Length(30)))
    val t1 = Eq(t, sizes.Get(0), 50)
    val t2 = Eq(t1, sizes.Get(1), 40)
    return Eq(t2, sizes.Get(2), 10)
}

func TestSolveZeroTotal(t T) T {
    val sizes = Solve(0, ArrayOf[Constraint](Length(3), Fill(1)))
    return Eq(t, sizes.Length(), 2)
}

// ============================================================================
// Widget-level Row / Column / Stack tests.
// ============================================================================

func TestRowTwoTextsSplitByLength(t T) T {
    val buf = NewBuffer(10, 1)
    val w = Row(ArrayOf[LayoutChild](
        Fixed(5, Text("HelloWorld")),
        Fixed(5, Text("12345")),
    ))
    RenderTo(w, Rect(X = 0, Y = 0, Width = 10, Height = 1), buf)
    return Eq(t, BufferText(buf, 0), "Hello12345")
}

func TestRowFillFillEvenSplit(t T) T {
    val buf = NewBuffer(10, 1)
    val w = Row(ArrayOf[LayoutChild](
        Flex(1, Text("aaaaaaaaaa")),
        Flex(1, Text("bbbbbbbbbb")),
    ))
    RenderTo(w, Rect(X = 0, Y = 0, Width = 10, Height = 1), buf)
    return Eq(t, BufferText(buf, 0), "aaaaabbbbb")
}

func TestRowLengthPlusFill(t T) T {
    val buf = NewBuffer(10, 1)
    val w = Row(ArrayOf[LayoutChild](
        Fixed(3, Text("IDs")),
        Flex(1, Text("bodybodyXX")),
    ))
    RenderTo(w, Rect(X = 0, Y = 0, Width = 10, Height = 1), buf)
    return Eq(t, BufferText(buf, 0), "IDsbodybod")
}

func TestColumnThreeRows(t T) T {
    val buf = NewBuffer(5, 3)
    val w = Column(ArrayOf[LayoutChild](
        Fixed(1, Text("aaaaa")),
        Fixed(1, Text("bbbbb")),
        Fixed(1, Text("ccccc")),
    ))
    RenderTo(w, Rect(X = 0, Y = 0, Width = 5, Height = 3), buf)
    val t1 = Eq(t, BufferText(buf, 0), "aaaaa")
    val t2 = Eq(t1, BufferText(buf, 1), "bbbbb")
    return Eq(t2, BufferText(buf, 2), "ccccc")
}

func TestColumnHeaderBodyFooter(t T) T {
    val buf = NewBuffer(5, 5)
    val w = Column(ArrayOf[LayoutChild](
        Fixed(1, Text("HEADR")),
        Flex(1,  FillCh('.')),
        Fixed(1, Text("FOOTR")),
    ))
    RenderTo(w, Rect(X = 0, Y = 0, Width = 5, Height = 5), buf)
    val t1 = Eq(t, BufferText(buf, 0), "HEADR")
    val t2 = Eq(t1, BufferText(buf, 1), ".....")
    val t3 = Eq(t2, BufferText(buf, 2), ".....")
    val t4 = Eq(t3, BufferText(buf, 3), ".....")
    return Eq(t4, BufferText(buf, 4), "FOOTR")
}

func TestStackMergesLayers(t T) T {
    val buf = NewBuffer(5, 1)
    val w = Stack(ArrayOf[Widget](FillCh('.'), Text("hi")))
    RenderTo(w, Rect(X = 0, Y = 0, Width = 5, Height = 1), buf)
    return Eq(t, BufferText(buf, 0), "hi...")
}

func TestRealDashboardLayout(t T) T {
    val buf = NewBuffer(20, 7)
    val w = Column(ArrayOf[LayoutChild](
        Fixed(1, Text("== TITLE ===========")),
        Flex(1, Row(ArrayOf[LayoutChild](
            Fixed(5, Text("NAV  ")),
            Flex(1, Border(Text("body"))),
        ))),
        Fixed(1, Text("[ready]             ")),
    ))
    RenderTo(w, Rect(X = 0, Y = 0, Width = 20, Height = 7), buf)
    val t1 = Eq(t, BufferText(buf, 0), "== TITLE ===========")
    val t2 = Eq(t1, BufferText(buf, 1), "NAV  ┌─────────────┐")
    return Eq(t2, BufferText(buf, 6), "[ready]             ")
}
