package gala_tui

import (
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/std"
)

// ============================================================================
// ConversationLog — append-only scrollback of variable-height entries.
//
// What `LogPanel` is for fixed-height log lines, ConversationLog is for
// rich chat messages: each entry has its OWN Widget body of arbitrary
// height (markdown answer, tool-call card with toggle state, code
// block + diff, etc.).
//
// Behaviour:
//   - Append a new entry → auto-scroll-to-bottom UNLESS the user
//     manually scrolled up (`StickToBottom = false`).
//   - PgUp / PgDn / arrow / wheel scroll moves the offset by one entry
//     and unsticks. Pressing End re-sticks.
//   - Click an entry's row → optional `onPickEntry(idx)` callback for
//     focusing / opening / collapsing.
//
// The viewport is a *line* viewport (not entry viewport): tall entries
// can be partially visible. This matches Claude Code's behaviour
// where a long markdown answer scrolls smoothly within the log.
// ============================================================================

struct ConversationEntry(
    Body   Widget,
    Height int,            // intrinsic / preferred line count for this entry
)

struct ConversationLog(
    Entries       Array[ConversationEntry],
    Offset        int,           // top visible line index across all entries
    StickToBottom bool,
)

// NewConversationLog builds an empty log that's stuck to the bottom by
// default — the first appended entry is immediately visible.
func NewConversationLog() ConversationLog =
    ConversationLog(
        Entries       = EmptyArray[ConversationEntry](),
        Offset        = 0,
        StickToBottom = true,
    )

// ----------------------------------------------------------------------------
// Update
// ----------------------------------------------------------------------------

sealed type ConversationLogEvent {
    case CvAppend(Entry ConversationEntry)
    case CvReplaceAt(Idx int, Entry ConversationEntry)
    case CvScrollUp(Lines int)
    case CvScrollDown(Lines int)
    case CvPageUp(Lines int)             // pass viewport height
    case CvPageDown(Lines int)
    case CvStickToBottom()
    case CvNoOp()
}

func ConversationLogUpdate(c ConversationLog, ev ConversationLogEvent) ConversationLog = ev match {
    case CvAppend(e)        => cvAppend(c, e)
    case CvReplaceAt(i, e)  => cvReplaceAt(c, i, e)
    case CvScrollUp(n)      => cvScroll(c, -n)
    case CvScrollDown(n)    => cvScroll(c, n)
    case CvPageUp(n)        => cvScroll(c, -n)
    case CvPageDown(n)      => cvScroll(c, n)
    case CvStickToBottom()  => ConversationLog(
                                   Entries = c.Entries,
                                   Offset = cvTotalLines(c.Entries),
                                   StickToBottom = true,
                               )
    case CvNoOp()           => c
}

// cvReplaceAt swaps the entry at `idx` with `e` while preserving the
// scroll state. Used by entries whose body changes after append (e.g.,
// a Disclosure tool-call card that toggles its own height when expanded
// or collapsed). Out-of-range `idx` returns `c` unchanged so a stale
// click doesn't crash the app.
func cvReplaceAt(c ConversationLog, idx int, e ConversationEntry) ConversationLog {
    if idx < 0 || idx >= c.Entries.Length() { return c }
    return ConversationLog(
        Entries       = c.Entries.Updated(idx, e),
        Offset        = c.Offset,
        StickToBottom = c.StickToBottom,
    )
}

func cvAppend(c ConversationLog, e ConversationEntry) ConversationLog {
    val newEntries = c.Entries.Append(e)
    val newOffset = if (c.StickToBottom) cvTotalLines(newEntries) else c.Offset
    return ConversationLog(
        Entries       = newEntries,
        Offset        = newOffset,
        StickToBottom = c.StickToBottom,
    )
}

func cvScroll(c ConversationLog, delta int) ConversationLog {
    val total = cvTotalLines(c.Entries)
    val proposed = c.Offset + delta
    val clamped = if (proposed < 0) 0
                  else if (proposed > total) total
                  else proposed
    val sticky = clamped >= total
    return ConversationLog(
        Entries       = c.Entries,
        Offset        = clamped,
        StickToBottom = sticky,
    )
}

func cvTotalLines(entries Array[ConversationEntry]) int {
    var sum = 0
    var i = 0
    val n = entries.Length()
    for i < n {
        sum = sum + entries.Get(i).Height
        i = i + 1
    }
    return sum
}

// ----------------------------------------------------------------------------
// View
// ----------------------------------------------------------------------------

// ConversationLogView paints the entries that fit in `height` rows
// starting from the offset. Lines above the offset are hidden; the
// last entry's tail sits at the bottom row when sticky.
//
// Each entry is wrapped in a `ViewportW` so partial visibility works:
// if an entry's height exceeds remaining space, we render only the
// visible portion.
func ConversationLogView(c ConversationLog, height int) Widget =
    cvBuildLayout(c, height, (body, _) => body)

// ConversationLogViewClick is the click-aware sibling: a left-click on
// a rendered entry dispatches `onPickEntry(idx)` where `idx` is the
// entry's index in `Entries` (0-based, oldest first). Per-entry hits
// at variable y / height — we can't use OnPickRow (uniform row height)
// — so each entry's body widget is wrapped in `OnClick` before being
// composed into the Column.
func ConversationLogViewClick[T any](
    c ConversationLog, height int, onPickEntry func(int) T,
) Widget =
    cvBuildLayout(c, height, (body, i) => body.OnClick[T](onPickEntry(i)))

// ConversationLogViewDrag is the drag-aware sibling: each rendered
// entry registers a drag region. The runtime threads drag state
// (see `runtime.gala::ResolveClickEvent`) and dispatches
// `msgFor(idx, DragPress)` on the press, `msgFor(idx, DragOver)` on
// every motion-while-held event whose cursor sits over a drag
// region (the idx is the CURRENT region under the cursor — which
// can be a sibling entry of the press as the user drags up or
// down), and `msgFor(idx, DragRelease)` on release with the idx
// of the ORIGINATING press. Apps use this for drag-to-select
// ranges: track an anchor on DragPress, slide the focus on each
// DragOver, freeze the range on DragRelease.
func ConversationLogViewDrag[T any](
    c ConversationLog, height int, msgFor func(int, DragPhase) T,
) Widget =
    cvBuildLayout(c, height, (body, i) =>
        body.OnDrag[T]((phase) => msgFor(i, phase)),
    )

// ConversationLogEntryAt maps a row offset within the rendered
// viewport to the entry index showing at that row, mirroring the
// sticky-bottom + offset math `cvBuildLayout` uses internally.
//
// Returns None when:
//   - rowInViewport is outside [0, height)
//   - the log is empty
//   - the row falls into negative space above the first visible
//     entry (only possible when scrolled past the top)
//
// `viewportH` should be the SAME height the matching
// `ConversationLogView*` call was rendered with — passing a
// different value produces wrong indices because the sticky-bottom
// calculation depends on it.
func ConversationLogEntryAt(
    c ConversationLog, viewportH int, rowInViewport int,
) Option[int] {
    if c.Entries.IsEmpty() { return None[int]() }
    if rowInViewport < 0 || rowInViewport >= viewportH { return None[int]() }
    val total = cvTotalLines(c.Entries)
    val viewportTop = if (c.StickToBottom) MaxInt(0, total - viewportH)
                      else c.Offset
    var lineCursor = 0
    var i = 0
    val n = c.Entries.Length()
    for i < n {
        val entry = c.Entries.Get(i)
        val entryStart = lineCursor
        val entryEnd = lineCursor + entry.Height
        val visTop = MaxInt(viewportTop, entryStart)
        val visBot = MinInt(viewportTop + viewportH, entryEnd)
        if visBot > visTop {
            val rowsBefore = visTop - viewportTop
            val rowsAfter  = visBot - viewportTop
            if rowInViewport >= rowsBefore && rowInViewport < rowsAfter {
                return Some(i)
            }
        }
        lineCursor = entryEnd
        i = i + 1
    }
    return None[int]()
}

// cvBuildLayout walks `c.Entries`, computes which slice of each entry
// is visible in the viewport, and lays them out in a Column. Each
// (already-viewported) entry body is passed through `wrapEntry` along
// with its entry index — view callers pass identity, click callers
// attach an OnClick. The walk is stateful (line cursor + remaining
// rows) so it stays imperative; the loop-bound Append is the single
// emit point per visible entry.
func cvBuildLayout(
    c ConversationLog,
    height int,
    wrapEntry func(Widget, int) Widget,
) Widget {
    if c.Entries.IsEmpty() || height <= 0 { return Empty() }
    val total = cvTotalLines(c.Entries)
    val viewportTop = if (c.StickToBottom) MaxInt(0, total - height)
                      else c.Offset
    var children = EmptyArray[LayoutChild]()
    var lineCursor = 0
    var rowsLeft = height
    var i = 0
    val n = c.Entries.Length()
    for i < n {
        if rowsLeft <= 0 { i = n; continue }
        val entry = c.Entries.Get(i)
        val entryStart = lineCursor
        val entryEnd = lineCursor + entry.Height
        val visTop = MaxInt(viewportTop, entryStart)
        val visBot = MinInt(viewportTop + height, entryEnd)
        if visBot > visTop {
            val skipTop = visTop - entryStart
            val take = visBot - visTop
            val body = if (skipTop > 0 || take < entry.Height)
                           ViewportW(
                               Inner         = entry.Body,
                               Offset        = skipTop,
                               ContentHeight = entry.Height,
                           )
                       else entry.Body
            children = children.Append(Fixed(take, wrapEntry(body, i)))
            rowsLeft = rowsLeft - take
        }
        lineCursor = entryEnd
        i = i + 1
    }
    return Column(children)
}
