package gala_tui

import (
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/test"
)

// ============================================================================
// DataTable tests.
// ============================================================================

func sampleDataTable() DataTable = NewDataTable(
    ArrayOf[string]("Name", "Age", "Role"),
    ArrayOf[Constraint](Length(8), Length(4), Fill(1)),
    ArrayOf[Array[string]](
        ArrayOf[string]("Alice",   "30", "admin"),
        ArrayOf[string]("Bob",     "25", "user"),
        ArrayOf[string]("Charlie", "40", "user"),
        ArrayOf[string]("Diana",   "35", "admin"),
    ),
)

// ----------------------------------------------------------------------------
// Selection + cursor movement
// ----------------------------------------------------------------------------

func TestDataTableStartsAtRowZero(t T) T {
    return Eq(t, sampleDataTable().Selected, 0)
}

func TestDataTableCursorDownAdvances(t T) T {
    val dt = DataTableUpdate(sampleDataTable(), DTCursorDown())
    return Eq(t, dt.Selected, 1)
}

func TestDataTableCursorClampsAtBottom(t T) T {
    var dt = sampleDataTable()
    var i = 0
    for i < 10 {
        dt = DataTableUpdate(dt, DTCursorDown())
        i = i + 1
    }
    // With 4 rows, max index is 3.
    return Eq(t, dt.Selected, 3)
}

func TestDataTableCursorUpClampsAtZero(t T) T {
    val dt = DataTableUpdate(sampleDataTable(), DTCursorUp())
    return Eq(t, dt.Selected, 0)
}

func TestDataTableHomeAndEnd(t T) T {
    var dt = sampleDataTable()
    dt = DataTableUpdate(dt, DTEnd())
    val t1 = Eq(t, dt.Selected, 3)
    dt = DataTableUpdate(dt, DTHome())
    return Eq(t1, dt.Selected, 0)
}

// ----------------------------------------------------------------------------
// Sorting
// ----------------------------------------------------------------------------

func TestDataTableSortCyclesAsc(t T) T {
    val dt = DataTableUpdate(sampleDataTable(), DTSort(Col = 0))
    val isAsc = dt.SortDir match {
        case SortAsc() => true
        case _         => false
    }
    val t1 = Eq(t, dt.SortCol, 0)
    return IsTrue(t1, isAsc)
}

func TestDataTableSortCyclesToDescOnSecond(t T) T {
    var dt = sampleDataTable()
    dt = DataTableUpdate(dt, DTSort(Col = 0))   // Asc
    dt = DataTableUpdate(dt, DTSort(Col = 0))   // Desc
    val isDesc = dt.SortDir match {
        case SortDesc() => true
        case _          => false
    }
    return IsTrue(t, isDesc)
}

func TestDataTableSortCyclesBackToNone(t T) T {
    var dt = sampleDataTable()
    dt = DataTableUpdate(dt, DTSort(Col = 0))   // Asc
    dt = DataTableUpdate(dt, DTSort(Col = 0))   // Desc
    dt = DataTableUpdate(dt, DTSort(Col = 0))   // None
    return Eq(t, dt.SortCol, -1)
}

func TestDataTableSortByNameAscPutsAliceFirst(t T) T {
    val dt = DataTableUpdate(sampleDataTable(), DTSort(Col = 0))
    val rows = dtVisible(dt)
    return Eq(t, rows.Get(0).Get(0), "Alice")
}

func TestDataTableSortByNameDescPutsDianaFirst(t T) T {
    var dt = sampleDataTable()
    dt = DataTableUpdate(dt, DTSort(Col = 0))
    dt = DataTableUpdate(dt, DTSort(Col = 0))   // Desc
    val rows = dtVisible(dt)
    // Alphabetically descending: Diana, Charlie, Bob, Alice.
    return Eq(t, rows.Get(0).Get(0), "Diana")
}

// ----------------------------------------------------------------------------
// Filtering
// ----------------------------------------------------------------------------

func TestDataTableFilterNarrowsRows(t T) T {
    val dt = DataTableUpdate(sampleDataTable(), DTFilter(Query = "admin"))
    val rows = dtVisible(dt)
    return Eq(t, rows.Length(), 2)                  // Alice + Diana
}

func TestDataTableFilterIsCaseInsensitive(t T) T {
    val dt = DataTableUpdate(sampleDataTable(), DTFilter(Query = "ADMIN"))
    val rows = dtVisible(dt)
    return Eq(t, rows.Length(), 2)
}

func TestDataTableFilterMatchesAnyColumn(t T) T {
    // "40" appears in the age column only.
    val dt = DataTableUpdate(sampleDataTable(), DTFilter(Query = "40"))
    val rows = dtVisible(dt)
    return Eq(t, rows.Length(), 1)
}

func TestDataTableClearFilterRestoresAll(t T) T {
    var dt = sampleDataTable()
    dt = DataTableUpdate(dt, DTFilter(Query = "admin"))
    dt = DataTableUpdate(dt, DTClearFilter())
    return Eq(t, dtVisible(dt).Length(), 4)
}

// ----------------------------------------------------------------------------
// SelectedRow
// ----------------------------------------------------------------------------

func TestDataTableSelectedRowReturnsCurrent(t T) T {
    var dt = sampleDataTable()
    dt = DataTableUpdate(dt, DTCursorDown())     // select Bob
    val row = SelectedRow(dt)
    return Eq(t, row.Get(0), "Bob")
}

func TestDataTableSelectedRowWithSortReturnsVisibleRow(t T) T {
    var dt = sampleDataTable()
    dt = DataTableUpdate(dt, DTSort(Col = 0))    // sorted asc: Alice Bob Charlie Diana
    dt = DataTableUpdate(dt, DTCursorDown())     // select Bob
    val row = SelectedRow(dt)
    return Eq(t, row.Get(0), "Bob")
}

// ----------------------------------------------------------------------------
// View
// ----------------------------------------------------------------------------

func TestDataTableViewRendersHeader(t T) T {
    val buf = NewBuffer(30, 6)
    RenderTo(DataTableView(sampleDataTable()),
        Rect(X = 0, Y = 0, Width = 30, Height = 6), buf)
    val row0 = BufferText(buf, 0)
    return IsTrue(t, dtRowHas(row0, "Name"))
}

func TestDataTableViewHasHorizontalRule(t T) T {
    val buf = NewBuffer(30, 6)
    RenderTo(DataTableView(sampleDataTable()),
        Rect(X = 0, Y = 0, Width = 30, Height = 6), buf)
    return Eq(t, buf.CharAt(0, 1), '─')
}

func TestDataTableViewHighlightsSelectedRow(t T) T {
    val buf = NewBuffer(30, 6)
    RenderTo(DataTableView(sampleDataTable()),
        Rect(X = 0, Y = 0, Width = 30, Height = 6), buf)
    // Selected row is first body row at y=2.
    return IsTrue(t, buf.StyleAt(0, 2).Reverse)
}

func TestDataTableSortedHeaderShowsArrow(t T) T {
    val dt = DataTableUpdate(sampleDataTable(), DTSort(Col = 0))
    val buf = NewBuffer(30, 3)
    RenderTo(DataTableView(dt), Rect(X = 0, Y = 0, Width = 30, Height = 3), buf)
    val row0 = BufferText(buf, 0)
    return IsTrue(t, dtRowHas(row0, "Name ↑"))
}

func TestDataTableEmptyAfterFilterShowsHint(t T) T {
    val dt = DataTableUpdate(sampleDataTable(), DTFilter(Query = "zzzzz"))
    val buf = NewBuffer(30, 4)
    RenderTo(DataTableView(dt), Rect(X = 0, Y = 0, Width = 30, Height = 4), buf)
    val combined = dtJoinRows(buf)
    return IsTrue(t, dtRowHas(combined, "no rows"))
}

// ----------------------------------------------------------------------------
// Helpers
// ----------------------------------------------------------------------------

func dtJoinRows(buf *Buffer) string {
    var s = ""
    var y = 0
    for y < buf.Height {
        s = s + BufferText(buf, y) + "\n"
        y = y + 1
    }
    return s
}

func dtRowHas(hay string, needle string) bool {
    val h = dtRuneArr(hay)
    val n = dtRuneArr(needle)
    val hn = h.Length()
    val nn = n.Length()
    if nn == 0 { return true }
    if nn > hn { return false }
    var i = 0
    for i <= hn - nn {
        var j = 0
        var ok = true
        for j < nn {
            if h.Get(i + j) != n.Get(j) {
                ok = false
                j = nn
            } else {
                j = j + 1
            }
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

func dtRuneArr(s string) Array[rune] {
    var acc = EmptyArray[rune]()
    for _, c := range s {
        acc = acc.Append(c)
    }
    return acc
}
