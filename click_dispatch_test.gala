package gala_tui

import (
    . "martianoff/gala/std"
    . "martianoff/gala/test"
    . "martianoff/gala/time_utils"
)

// ============================================================================
// Tests for the click-dispatch resolver — `ResolveClickEvent` plus the
// pending-state drain. These pin down Model B semantics:
//
//   - single-click on a widget with only OnClick fires immediately
//   - single-click on a widget with both OnClick + OnDoubleClick is
//     deferred (pending)
//   - second click within window upgrades pending to double; suppresses
//     the deferred single
//   - second click outside window (different position, or after window)
//     fires the pending single + a fresh first-click
//   - DrainExpiredPending fires the deferred single after the window
// ============================================================================

sealed type CdMsg {
    case CdSingle(N int)
    case CdDouble(N int)
    case CdDrag(Idx int, Phase DragPhase)
    case CdNone()
}

func cdFallback() func(InputEvent) CdMsg = (ev) => CdNone()

func cdLeftClick(x int, y int) InputEvent =
    MouseInput(Ev = MouseEvent(Btn = MouseLeft(), X = x, Y = y, Pressed = true, Motion = false))

func cdLeftRelease(x int, y int) InputEvent =
    MouseInput(Ev = MouseEvent(Btn = MouseLeft(), X = x, Y = y, Pressed = false, Motion = false))

func cdLeftDrag(x int, y int) InputEvent =
    MouseInput(Ev = MouseEvent(Btn = MouseLeft(), X = x, Y = y, Pressed = true, Motion = true))

// ----------------------------------------------------------------------------
// Single-click only
// ----------------------------------------------------------------------------

func TestResolveSingleClickOnlyFiresImmediately(t T) T {
    val hits = NewHitRegistry()
    hits.Register(Rect(X = 0, Y = 0, Width = 10, Height = 1), CdSingle(N = 7))

    val (msgs, pend) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), Now(), hits, None[ClickPending](), cdFallback(),
    )
    val t1 = Eq(t, msgs.Length(), 1)
    val isSingle = msgs.Get(0) match {
        case CdSingle(n) => n == 7
        case _           => false
    }
    val t2 = IsTrue(t1, isSingle)
    return IsFalse(t2, pend.IsDefined())
}

func TestResolveMissedClickFallsThroughToFallback(t T) T {
    val hits = NewHitRegistry()
    hits.Register(Rect(X = 0, Y = 0, Width = 10, Height = 1), CdSingle(N = 1))

    val (msgs, pend) = ResolveClickEvent[CdMsg](
        cdLeftClick(50, 0), Now(), hits, None[ClickPending](), cdFallback(),
    )
    val isFallback = msgs.Get(0) match {
        case CdNone() => true
        case _        => false
    }
    val t1 = IsTrue(t, isFallback)
    return IsFalse(t1, pend.IsDefined())
}

// ----------------------------------------------------------------------------
// Double-click + pending
// ----------------------------------------------------------------------------

// Click on a widget with both OnClick and OnDoubleClick → defer the
// single. No message dispatched yet; pending state is set.
func TestResolveSinglePlusDoubleDefersTheSingle(t T) T {
    val hits = NewHitRegistry()
    val rect = Rect(X = 0, Y = 0, Width = 10, Height = 1)
    hits.Register(rect, CdSingle(N = 1))
    hits.RegisterDouble(rect, CdDouble(N = 99))

    val (msgs, pend) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), Now(), hits, None[ClickPending](), cdFallback(),
    )
    val t1 = Eq(t, msgs.Length(), 0)
    return IsTrue(t1, pend.IsDefined())
}

// Real terminals deliver a press AND a release for each click, so a
// real double-click is press / release / press / release. The release
// between the two presses must NOT flush the pending single — that
// was the bug that made tree fold/unfold not work in the megademo.
func TestResolveReleaseBetweenPressesPreservesPending(t T) T {
    val hits = NewHitRegistry()
    val rect = Rect(X = 0, Y = 0, Width = 10, Height = 1)
    hits.Register(rect, CdSingle(N = 1))
    hits.RegisterDouble(rect, CdDouble(N = 99))

    val now = Now()
    val (msgs1, pend1) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), now, hits, None[ClickPending](), cdFallback(),
    )
    val (msgsRel, pendRel) = ResolveClickEvent[CdMsg](
        cdLeftRelease(5, 0), now.Plus(Milliseconds(int64(10))),
        hits, pend1, cdFallback(),
    )
    val (msgs2, pend2) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), now.Plus(Milliseconds(int64(80))),
        hits, pendRel, cdFallback(),
    )
    val t1 = Eq(t, msgs1.Length(), 0)              // press defers, no dispatch
    // Release passes through to the fallback (apps can handle it if
    // they want) but the pending double-click state is *not* flushed.
    val t2 = Eq(t1, msgsRel.Length(), 1)           // fallback dispatched
    val isReleaseFallback = msgsRel.Get(0) match {
        case CdNone() => true
        case _        => false
    }
    val t3 = IsTrue(t2, isReleaseFallback)
    val t4 = IsTrue(t3, pendRel.IsDefined())       // pending still around after release
    val t5 = Eq(t4, msgs2.Length(), 1)             // 2nd press fires double
    val isDouble = msgs2.Get(0) match {
        case CdDouble(n) => n == 99
        case _           => false
    }
    val t6 = IsTrue(t5, isDouble)
    return IsFalse(t6, pend2.IsDefined())
}

// Two clicks at the same coords within window → fires double, suppresses
// the deferred single. Net dispatched: just CdDouble.
func TestResolveTwoClicksWithinWindowFiresDouble(t T) T {
    val hits = NewHitRegistry()
    val rect = Rect(X = 0, Y = 0, Width = 10, Height = 1)
    hits.Register(rect, CdSingle(N = 1))
    hits.RegisterDouble(rect, CdDouble(N = 99))

    val now = Now()
    val (msgs1, pend1) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), now, hits, None[ClickPending](), cdFallback(),
    )
    val (msgs2, pend2) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), now.Plus(Milliseconds(int64(50))),
        hits, pend1, cdFallback(),
    )
    val t1 = Eq(t, msgs1.Length(), 0)              // first click defers
    val t2 = Eq(t1, msgs2.Length(), 1)             // second click fires once
    val isDouble = msgs2.Get(0) match {
        case CdDouble(n) => n == 99
        case _           => false
    }
    val t3 = IsTrue(t2, isDouble)
    return IsFalse(t3, pend2.IsDefined())          // pending cleared
}

// Two clicks at the same coords but the second is OUTSIDE the window
// → first click's deferred single fires (orphaned), second click is
// handled fresh. Net: CdSingle from the first, plus a fresh dispatch
// for the second.
func TestResolveSecondClickOutOfWindowFiresOrphan(t T) T {
    val hits = NewHitRegistry()
    val rect = Rect(X = 0, Y = 0, Width = 10, Height = 1)
    hits.Register(rect, CdSingle(N = 1))
    hits.RegisterDouble(rect, CdDouble(N = 99))

    val now = Now()
    val (_, pend1) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), now, hits, None[ClickPending](), cdFallback(),
    )
    // Advance way past the window (1 second).
    val (msgs2, pend2) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), now.Plus(Milliseconds(int64(1000))),
        hits, pend1, cdFallback(),
    )
    // First call deferred → 0 msgs, pending set.
    // Second call: pending expired → flush its deferred (CdSingle 1).
    //              Then this click is fresh: registers as new pending.
    val t1 = Eq(t, msgs2.Length(), 1)
    val isOrphanSingle = msgs2.Get(0) match {
        case CdSingle(n) => n == 1
        case _           => false
    }
    val t2 = IsTrue(t1, isOrphanSingle)
    return IsTrue(t2, pend2.IsDefined())          // new pending for this click
}

// Click far away from a pending → flush pending's deferred, handle
// new click fresh.
func TestResolveClickAtDifferentPositionFlushesPending(t T) T {
    val hits = NewHitRegistry()
    val rectA = Rect(X = 0, Y = 0, Width = 10, Height = 1)
    val rectB = Rect(X = 50, Y = 0, Width = 10, Height = 1)
    hits.Register(rectA, CdSingle(N = 1))
    hits.RegisterDouble(rectA, CdDouble(N = 99))
    hits.Register(rectB, CdSingle(N = 2))

    val now = Now()
    val (_, pend1) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), now, hits, None[ClickPending](), cdFallback(),
    )
    val (msgs2, _) = ResolveClickEvent[CdMsg](
        cdLeftClick(55, 0), now.Plus(Milliseconds(int64(50))),
        hits, pend1, cdFallback(),
    )
    // Second click at different coords: flush pending's CdSingle(1)
    // then dispatch CdSingle(2) for the new click.
    val t1 = Eq(t, msgs2.Length(), 2)
    val first = msgs2.Get(0) match {
        case CdSingle(n) => n
        case _           => -1
    }
    val second = msgs2.Get(1) match {
        case CdSingle(n) => n
        case _           => -1
    }
    val t2 = Eq(t1, first, 1)
    return Eq(t2, second, 2)
}

// ----------------------------------------------------------------------------
// DrainExpiredPending
// ----------------------------------------------------------------------------

// After the window elapses with no follow-up click, DrainExpiredPending
// fires the deferred single.
func TestDrainExpiredFiresDeferred(t T) T {
    val now = Now()
    val pend = Some[ClickPending](ClickPending(
        X = 5, Y = 0, At = now,
        Deferred = Some[any](CdSingle(N = 42)),
    ))
    val (msgs, after) = DrainExpiredPending[CdMsg](
        pend, now.Plus(Milliseconds(int64(500))),     // 500ms > 400ms window
    )
    val t1 = Eq(t, msgs.Length(), 1)
    val isSingle = msgs.Get(0) match {
        case CdSingle(n) => n == 42
        case _           => false
    }
    val t2 = IsTrue(t1, isSingle)
    return IsFalse(t2, after.IsDefined())
}

// Within the window, drain is a no-op.
func TestDrainWithinWindowIsNoOp(t T) T {
    val now = Now()
    val pend = Some[ClickPending](ClickPending(
        X = 5, Y = 0, At = now,
        Deferred = Some[any](CdSingle(N = 42)),
    ))
    val (msgs, after) = DrainExpiredPending[CdMsg](
        pend, now.Plus(Milliseconds(int64(100))),    // 100ms < 400ms window
    )
    val t1 = Eq(t, msgs.Length(), 0)
    return IsTrue(t1, after.IsDefined())
}

// Pending with no deferred (only a double-click was registered, no
// single) — drain clears state without dispatching anything.
func TestDrainWithoutDeferredJustClears(t T) T {
    val now = Now()
    val pend = Some[ClickPending](ClickPending(
        X = 5, Y = 0, At = now,
        Deferred = None[any](),
    ))
    val (msgs, after) = DrainExpiredPending[CdMsg](
        pend, now.Plus(Milliseconds(int64(500))),
    )
    val t1 = Eq(t, msgs.Length(), 0)
    return IsFalse(t1, after.IsDefined())
}

// ----------------------------------------------------------------------------
// Drag dispatch — DraggableW press / DragOver / DragRelease lifecycle.
// ----------------------------------------------------------------------------

// cdDragPayload builds the type-erased OnDrag payload for entry idx
// — `func(DragPhase) any` returning a CdDrag tagged with this idx.
func cdDragPayload(idx int) any =
    (phase DragPhase) => any(CdDrag(Idx = idx, Phase = phase))

// HitAtDrag returns the registered payload at the given coordinate,
// distinct from the click-only HitAt path.
func TestHitAtDragReturnsRegisteredPayload(t T) T {
    val hits = NewHitRegistry()
    hits.RegisterDrag(Rect(X = 0, Y = 0, Width = 10, Height = 1), cdDragPayload(7))
    val opt = hits.HitAtDrag(5, 0)
    return IsTrue(t, opt.IsDefined())
}

// HitAt (click) does NOT return drag entries — separate lookup paths
// keep click and drag dispatch from cross-firing.
func TestHitAtSkipsDragEntries(t T) T {
    val hits = NewHitRegistry()
    hits.RegisterDrag(Rect(X = 0, Y = 0, Width = 10, Height = 1), cdDragPayload(0))
    return IsFalse(t, hits.HitAt(5, 0).IsDefined())
}

// Press on a drag region produces DragPress with the right idx and
// engages the drag-active slot.
func TestResolveDragPressEngagesDragActive(t T) T {
    val hits = NewHitRegistry()
    hits.RegisterDrag(Rect(X = 0, Y = 0, Width = 10, Height = 1), cdDragPayload(3))
    val res = ResolveClickEventWithDrag[CdMsg](
        cdLeftClick(5, 0), Now(), hits,
        None[ClickPending](), None[DragActive](), cdFallback(),
    )
    val gotPress = res.Msgs.Length() == 1 && (res.Msgs.Get(0) match {
        case CdDrag(idx, DragPress()) => idx == 3
        case _                        => false
    })
    val t1 = IsTrue(t, gotPress)
    return IsTrue(t1, res.Drag.IsDefined())
}

// Motion-while-held over a different drag region produces DragOver
// against the CURRENT region's idx (not the press's).
func TestResolveDragMotionFiresOverWithCurrentEntry(t T) T {
    val hits = NewHitRegistry()
    hits.RegisterDrag(Rect(X = 0, Y = 0, Width = 10, Height = 1), cdDragPayload(0))
    hits.RegisterDrag(Rect(X = 0, Y = 1, Width = 10, Height = 1), cdDragPayload(1))
    // Press on entry 0...
    val r1 = ResolveClickEventWithDrag[CdMsg](
        cdLeftClick(5, 0), Now(), hits,
        None[ClickPending](), None[DragActive](), cdFallback(),
    )
    // ...then drag motion to entry 1.
    val r2 = ResolveClickEventWithDrag[CdMsg](
        cdLeftDrag(5, 1), Now(), hits,
        r1.Pending, r1.Drag, cdFallback(),
    )
    val gotOverOnEntry1 = r2.Msgs.Length() == 1 && (r2.Msgs.Get(0) match {
        case CdDrag(idx, DragOver()) => idx == 1
        case _                       => false
    })
    return IsTrue(t, gotOverOnEntry1)
}

// Release dispatches DragRelease against the ORIGINATING press's
// payload — not the cursor's current position. The user often
// releases off the original region; the consumer still needs a
// definitive "drag is over" signal tied to the press.
func TestResolveDragReleaseUsesOriginatingPressPayload(t T) T {
    val hits = NewHitRegistry()
    hits.RegisterDrag(Rect(X = 0, Y = 0, Width = 10, Height = 1), cdDragPayload(7))
    // Press entry 7.
    val r1 = ResolveClickEventWithDrag[CdMsg](
        cdLeftClick(5, 0), Now(), hits,
        None[ClickPending](), None[DragActive](), cdFallback(),
    )
    // Release at coords with no registered drag region — the runtime
    // must still fire DragRelease against entry 7's payload.
    val r2 = ResolveClickEventWithDrag[CdMsg](
        cdLeftRelease(50, 50), Now(), hits,
        r1.Pending, r1.Drag, cdFallback(),
    )
    val gotReleaseOn7 = r2.Msgs.Length() == 1 && (r2.Msgs.Get(0) match {
        case CdDrag(idx, DragRelease()) => idx == 7
        case _                          => false
    })
    val t1 = IsTrue(t, gotReleaseOn7)
    return IsFalse(t1, r2.Drag.IsDefined())
}

// Backward-compat: ResolveClickEvent (no drag param) still works the
// same as before for click-only consumers.
func TestResolveClickEventClickOnlyAPIIsUnchanged(t T) T {
    val hits = NewHitRegistry()
    hits.Register(Rect(X = 0, Y = 0, Width = 10, Height = 1), CdSingle(N = 9))
    val (msgs, _) = ResolveClickEvent[CdMsg](
        cdLeftClick(5, 0), Now(), hits, None[ClickPending](), cdFallback(),
    )
    return IsTrue(t, msgs.Length() == 1 && (msgs.Get(0) match {
        case CdSingle(n) => n == 9
        case _           => false
    }))
}
