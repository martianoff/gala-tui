package main

import (
    . "github.com/martianoff/gala-tui"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/std"
    . "martianoff/gala/time_utils"
)

// ============================================================================
// chat — Claude-Code-style chat TUI demo using gala-tui's new widget set.
//
//     gala build ./examples/chat
//     ./gala_tui.exe                          # binary takes the module name
//
// Layout:
//   - Header (1 row)
//   - ConversationLog (rest)        ← scrollback of messages
//   - Streaming preview (2 rows)    ← visible while a response streams
//   - Footer hint (1 row)
//   - TextArea composer (3 rows)    ← multi-line input at the bottom
//
// What you can do:
//   - Type → text appears in the composer.
//   - Enter → submit; pushes a "you" message into the log, then a fake
//     "ai" response starts streaming (tokens appear via TickSub).
//   - Tab inserts a newline in the composer (terminals can't
//     distinguish Shift+Enter, so we use Tab).
//   - Type `/` at the start of a line to open a slash-command
//     popup; click an entry or press Enter to run the command:
//        /help    show this help message
//        /clear   wipe the conversation log
//        /quit    exit the app
//   - ↑/↓ at the top/bottom of the composer steps through history
//     (or moves through the slash popup if it's open).
//   - PageUp/PageDown scrolls the conversation log.
//   - End re-sticks the log to the bottom.
//   - Ctrl+C / Ctrl+D quits.
//
// All Msg cases use the `Ch` prefix to avoid shadowing dot-imported
// case constructors from gala-tui.
// ============================================================================

// ----- Domain types --------------------------------------------------------

sealed type Author { case ChUser() case ChAssistant() }

struct ChatMessage(Who Author, Body string)

// ----- Model ---------------------------------------------------------------

struct Model(
    Composer  TextArea,
    Log       ConversationLog,
    Streaming StreamingText,
    InFlight  bool,                  // true while a response is streaming
    Tick      int,                   // animates the streaming cursor
    SlashSel  int,                   // selected row in the slash popup (when visible)
)

func initial() Model = Model(
    Composer  = NewTextArea(),
    Log       = appendLog(NewConversationLog(), ChAssistant(),
                  "Welcome — type a message and press Enter. " +
                  "Tab inserts a newline. ↑/↓ recalls history. " +
                  "Type `/` for a command list. PgUp/PgDn scrolls. " +
                  "Ctrl+C quits."),
    Streaming = NewStreamingText(),
    InFlight  = false,
    Tick      = 0,
    SlashSel  = 0,
)

// ----- Messages ------------------------------------------------------------

sealed type Msg {
    case ChChar(C rune)
    case ChBackspace()
    case ChCursorUp()
    case ChCursorDown()
    case ChCursorLeft()
    case ChCursorRight()
    case ChNewline()
    case ChSubmit()
    case ChScrollUp()
    case ChScrollDown()
    case ChStickEnd()
    case ChTick()
    case ChStreamChunk(S string)
    case ChStreamDone()
    case ChSlashSelect(Idx int)         // mouse click on slash row
    case ChEsc()                          // close popup
    case ChQuit()
    case ChClearLog()                     // /clear handler
    case ChNoOp()
}

// ----- Slash commands ------------------------------------------------------

struct SlashCommand(Name string, Hint string, Build func() Msg)

func slashCommands() Array[SlashCommand] = ArrayOf[SlashCommand](
    SlashCommand(Name = "/help",  Hint = "show help",            Build = () => ChNoOp()),
    SlashCommand(Name = "/clear", Hint = "clear the log",        Build = () => ChClearLog()),
    SlashCommand(Name = "/quit",  Hint = "exit the app",         Build = () => ChQuit()),
)

// Visible slash popup ↔ composer starts with `/`.
func slashPopupOpen(m Model) bool =
    TextAreaContent(m.Composer) != "" &&
    runeAt(TextAreaContent(m.Composer), 0) == '/'

func runeAt(s string, idx int) rune {
    var i = 0
    for _, c := range s {
        if i == idx { return c }
        i = i + 1
    }
    return rune(0)
}

func filteredSlashCommands(m Model) Array[SlashCommand] {
    val q = TextAreaContent(m.Composer)
    val cmds = slashCommands()
    if q == "" || runeAt(q, 0) != '/' { return cmds }
    return cmds.Filter((cmd) => stringHasPrefix(cmd.Name, q))
}

func stringHasPrefix(s string, prefix string) bool {
    var i = 0
    val pn = RuneCount(prefix)
    for _, c := range s {
        if i >= pn { return true }
        // Compare i-th rune of s with i-th rune of prefix.
        var j = 0
        var p = rune(0)
        for _, pc := range prefix {
            if j == i { p = pc; j = pn; }
            else { j = j + 1 }
        }
        if c != p { return false }
        i = i + 1
        if i >= pn { return true }
    }
    return RuneCount(s) >= pn
}

// ----- Update --------------------------------------------------------------

func update(m Model, msg Msg) Tuple[Model, Cmd[Msg]] = msg match {
    case ChQuit()           => (m, QuitCmd[Msg]())
    case ChNoOp()           => (m, NoCmd[Msg]())
    case ChChar(c)          => onCharInPopupAware(m, c)
    case ChBackspace()      => (m.Copy(Composer = TextAreaUpdate(m.Composer, TaBackspace()),
                                         SlashSel = 0), NoCmd[Msg]())
    case ChCursorUp()       => onCursorUp(m)
    case ChCursorDown()     => onCursorDown(m)
    case ChCursorLeft()     => (m.Copy(Composer = TextAreaUpdate(m.Composer, TaCursorLeft())), NoCmd[Msg]())
    case ChCursorRight()    => (m.Copy(Composer = TextAreaUpdate(m.Composer, TaCursorRight())), NoCmd[Msg]())
    case ChNewline()        => (m.Copy(Composer = TextAreaUpdate(m.Composer, TaInsertNewline())), NoCmd[Msg]())
    case ChScrollUp()       => (m.Copy(Log = ConversationLogUpdate(m.Log, CvScrollUp(Lines = 3))), NoCmd[Msg]())
    case ChScrollDown()     => (m.Copy(Log = ConversationLogUpdate(m.Log, CvScrollDown(Lines = 3))), NoCmd[Msg]())
    case ChStickEnd()       => (m.Copy(Log = ConversationLogUpdate(m.Log, CvStickToBottom())), NoCmd[Msg]())
    case ChTick()           => (m.Copy(Tick = m.Tick + 1), NoCmd[Msg]())
    case ChSubmit()         => onSubmit(m)
    case ChStreamChunk(s)   => onStreamChunk(m, s)
    case ChStreamDone()     => onStreamDone(m)
    case ChEsc()            => (m.Copy(Composer = TextAreaUpdate(m.Composer, TaClear()),
                                         SlashSel = 0), NoCmd[Msg]())
    case ChSlashSelect(idx) => onSlashSelect(m, idx)
    case ChClearLog()       => (m.Copy(Log = NewConversationLog(),
                                         Composer = TextAreaUpdate(m.Composer, TaClear()),
                                         SlashSel = 0), NoCmd[Msg]())
}

func onCharInPopupAware(m Model, c rune) Tuple[Model, Cmd[Msg]] {
    val nm = m.Copy(
        Composer = TextAreaUpdate(m.Composer, TaInsert(C = c)),
        SlashSel = 0,
    )
    return (nm, NoCmd[Msg]())
}

// Cursor-up: in the slash popup, move selection up; otherwise step
// composer / history as before.
func onCursorUp(m Model) Tuple[Model, Cmd[Msg]] {
    if slashPopupOpen(m) {
        val cmds = filteredSlashCommands(m)
        val n = cmds.Length()
        if n == 0 { return (m, NoCmd[Msg]()) }
        val nextSel = if (m.SlashSel - 1 < 0) n - 1 else m.SlashSel - 1
        return (m.Copy(SlashSel = nextSel), NoCmd[Msg]())
    }
    return (m.Copy(Composer = TextAreaUpdate(m.Composer, TaCursorUp())), NoCmd[Msg]())
}

func onCursorDown(m Model) Tuple[Model, Cmd[Msg]] {
    if slashPopupOpen(m) {
        val cmds = filteredSlashCommands(m)
        val n = cmds.Length()
        if n == 0 { return (m, NoCmd[Msg]()) }
        val nextSel = if (m.SlashSel + 1 >= n) 0 else m.SlashSel + 1
        return (m.Copy(SlashSel = nextSel), NoCmd[Msg]())
    }
    return (m.Copy(Composer = TextAreaUpdate(m.Composer, TaCursorDown())), NoCmd[Msg]())
}

func onSlashSelect(m Model, idx int) Tuple[Model, Cmd[Msg]] {
    val cmds = filteredSlashCommands(m)
    if idx < 0 || idx >= cmds.Length() {
        return (m, NoCmd[Msg]())
    }
    val cmd = cmds.Get(idx)
    val withClearedComposer = m.Copy(
        Composer = TextAreaUpdate(m.Composer, TaClear()),
        SlashSel = 0,
    )
    return (withClearedComposer, MsgCmd[Msg](Msg = cmd.Build()))
}

func onSubmit(m Model) Tuple[Model, Cmd[Msg]] {
    // Slash-popup is open: Enter selects the highlighted command.
    if slashPopupOpen(m) {
        return onSlashSelect(m, m.SlashSel)
    }
    val text = TextAreaContent(m.Composer)
    if text == "" { return (m, NoCmd[Msg]()) }
    val taSubmitted = TextAreaUpdate(m.Composer, TaSubmit())
    val logWithUser = appendLog(m.Log, ChUser(), text)
    val started = NewStreamingText()
    val resp = fakeReply(text)
    // Schedule the streaming chunks: each chunk arrives 80ms apart.
    val chunkCmds = streamChunkCmds(resp)
    val finalCmd = AfterDelay[Msg](
        Milliseconds(int64(80 * resp.Length() + 200)),
        () => ChStreamDone(),
    )
    val cmd = BatchCmd[Msg](Cmds = chunkCmds.Append(finalCmd))
    return (m.Copy(
        Composer  = taSubmitted,
        Log       = logWithUser,
        Streaming = started,
        InFlight  = true,
    ), cmd)
}

func onStreamChunk(m Model, chunk string) Tuple[Model, Cmd[Msg]] =
    (m.Copy(Streaming = StreamingTextUpdate(m.Streaming, StAppend(Chunk = chunk))),
     NoCmd[Msg]())

func onStreamDone(m Model) Tuple[Model, Cmd[Msg]] {
    val text = m.Streaming.Buffer
    val logWithReply = appendLog(m.Log, ChAssistant(), text)
    return (m.Copy(
        Log       = logWithReply,
        Streaming = StreamingTextUpdate(m.Streaming, StReset()),
        InFlight  = false,
    ), NoCmd[Msg]())
}

// ----- Streaming simulation ------------------------------------------------

// Split the canned reply into ~5-char chunks; emit one every 80 ms.
func streamChunkCmds(text Array[string]) Array[Cmd[Msg]] =
    ArrayTabulate(text.Length(), (i) => AfterDelay[Msg](
        Milliseconds(int64(80 * (i + 1))),
        () => ChStreamChunk(S = text.Get(i)),
    ))

// fakeReply produces a canned response by chopping a quirky message
// into 5-rune chunks. In a real app these would be tokens streamed
// from an HTTP response.
func fakeReply(prompt string) Array[string] {
    val canned = "I hear you said \"" + prompt + "\". " +
                 "Here's a streaming demo of gala-tui's StreamingText " +
                 "+ ConversationLog widgets. Each chunk arrives via a " +
                 "FutureCmd so the UI updates between renders without " +
                 "blocking the input loop."
    return chatRunes(canned).Grouped(5).Map((g) => string(g.ToGoSlice()))
}

func chatRunes(s string) Array[rune] {
    var acc = EmptyArray[rune]()
    for _, c := range s { acc = acc.Append(c) }
    return acc
}

// ----- Log helpers ---------------------------------------------------------
//
// The conversation log stores ConversationEntry values whose `Height` is
// the EXACT number of rendered rows the entry will occupy. Scroll math
// (offset, viewport top/bottom, partial-visibility clipping) all relies
// on that equality — if `Height` undercounts the rendered rows, tall
// entries get clipped to a single row of body and the visible region
// drifts as the user scrolls.
//
// To keep `Height` honest we pre-wrap the body using the same routine
// `ParagraphW` uses at render time (`WrapParagraph`), then build the
// entry view as a Column of fixed-1-height Text rows from those exact
// wrapped lines. No `Flex` — every row's height is statically known.
//
// `bodyTextWidth(termW)` is the width passed to wrap; it accounts for
// the leading `"  "` margin we render.

func appendLog(log ConversationLog, who Author, body string) ConversationLog {
    val (termW, _) = TermSize()
    val width = bodyTextWidth(termW)
    val wrapped = WrapParagraph(body, width)
    val entry = ConversationEntry(
        Body   = messageView(who, wrapped),
        Height = messageHeight(wrapped),
    )
    return ConversationLogUpdate(log, CvAppend(Entry = entry))
}

// bodyTextWidth: terminal width minus the 2-cell left margin we prepend
// to body lines. Floor at 20 so very narrow terminals don't divide-by-zero
// inside wrapParagraph.
func bodyTextWidth(termW int) int = MaxInt(20, termW - 2)

// messageHeight: exact rendered row count = header + wrapped body lines
// + spacer. Empty body still consumes one row so successive empty
// entries don't overlap visually.
func messageHeight(wrapped Array[string]) int =
    1 + MaxInt(1, wrapped.Length()) + 1

func messageView(who Author, wrapped Array[string]) Widget {
    val (label, color) = who match {
        case ChUser()      => ("You", BrightCyan())
        case ChAssistant() => ("AI",  BrightGreen())
    }
    val header = TextStyled("  " + label + " ",
        DefaultStyle().WithBold().WithFg(color))
    val bodyRows = wrapped.Map((line) => Fixed(1, Text("  " + line)))
    val children = ArrayOf[LayoutChild](Fixed(1, header))
        .AppendAll(if (bodyRows.IsEmpty()) ArrayOf[LayoutChild](Fixed(1, Text(""))) else bodyRows)
        .Append(Fixed(1, Text("")))
    return Column(children)
}

// ----- View ----------------------------------------------------------------

func view(m Model) Widget {
    val (_, h) = TermSize()
    val composerH = 3
    val streamingH = if (m.InFlight) 3 else 0
    val footerH = 1
    val headerH = 2
    val logH = h - headerH - streamingH - footerH - composerH
    val logHClamped = if (logH < 1) 1 else logH
    val log = ConversationLogView(m.Log, logHClamped)
    val streamingPane = if (m.InFlight)
                            BorderOf(StreamingTextStyled(
                                m.Streaming, m.Tick,
                                DefaultStyle().WithFg(BrightGreen())),
                                SingleBorder())
                        else Empty()
    val composerBorder = if (m.InFlight) th_dim() else th_focus()
    val composer = BorderOf(
        TextAreaView(m.Composer, !m.InFlight, "Type a message…"),
        composerBorder,
    )
    val base = Column(ArrayOf[LayoutChild](
        Fixed(headerH, headerWidget(m)),
        Flex(1, log),
        Fixed(streamingH, streamingPane),
        Fixed(footerH, footerWidget()),
        Fixed(composerH, composer),
    ))
    if !slashPopupOpen(m) {
        return base
    }
    val cmds = filteredSlashCommands(m)
    if cmds.IsEmpty() { return base }
    val popH = cmds.Length() + 2          // border + N rows
    val popW = 32
    // Composer is at the very bottom; popup floats just above it.
    val composerTop = h - composerH
    val popY = composerTop - popH
    val popX = 2
    val popupBody = slashPopupBody(cmds, m.SlashSel)
    val popup = Popup(popX, popY, popW, popH, popupBody)
    return PopupOver(base, popup.OnClick(ChNoOp()))
}

func slashPopupBody(cmds Array[SlashCommand], selected int) Widget {
    val rows = cmds.ZipWithIndex().Map((p) =>
        Fixed(1, slashRowWidget(p.V1, p.V2 == selected)))
    val list = Column(rows)
    return list.OnPickRow[Msg](cmds.Length(), (i) => ChSlashSelect(Idx = i))
}

func slashRowWidget(cmd SlashCommand, selected bool) Widget {
    val style = if (selected)
                    DefaultStyle().WithBold().WithReverse().WithFg(BrightYellow())
                else
                    DefaultStyle()
    val label = " " + cmd.Name + "  " + cmd.Hint + " "
    return TextStyled(label, style)
}

func headerWidget(m Model) Widget {
    val title = TextStyled(" gala-tui chat — Ctrl+C quits, Tab newline, ↑/↓ history, PgUp/PgDn scroll ",
        DefaultStyle().WithBold().WithFg(BrightWhite()).On(Blue()))
    return Column(ArrayOf[LayoutChild](
        Fixed(1, title),
        Fixed(1, FillCh(' ')),
    ))
}

func footerWidget() Widget =
    TextStyled("  Press End to re-stick the log to the bottom.",
        DefaultStyle().WithDim())

func th_dim() BorderKind   = SingleBorder()
func th_focus() BorderKind = ThickBorder()

// ----- Input adapter -------------------------------------------------------

func keyToMsg(ev KeyEvent) Msg {
    if KeyMatchesAny(ev, "ctrl+c", "ctrl+d") { return ChQuit() }
    return ev.Key match {
        case Char(c)    => ChChar(C = c)
        case Backspace() => ChBackspace()
        case Up()       => ChCursorUp()
        case Down()     => ChCursorDown()
        case ArrowLeft() => ChCursorLeft()
        case ArrowRight() => ChCursorRight()
        case Enter()    => ChSubmit()
        case Tab()      => ChNewline()
        case PageUp()   => ChScrollUp()
        case PageDown() => ChScrollDown()
        case End()      => ChStickEnd()
        case Esc()      => ChEsc()
        case _          => ChNoOp()
    }
}

func inputToMsg(ev InputEvent) Msg = ev match {
    case KeyInput(k)   => keyToMsg(k)
    case MouseInput(m) => m.Btn match {
        case MouseScrollUp()   => ChScrollUp()
        case MouseScrollDown() => ChScrollDown()
        case _                 => ChNoOp()
    }
    case _             => ChNoOp()
}

func main() {
    val program = Program[Model, Msg](
        Initial = initial(),
        Update  = (m, msg) => update(m, msg),
        View    = (m) => view(m),
    )
    val sub = TickSub[Msg](
        Interval = Milliseconds(int64(100)),
        Make     = () => ChTick(),
    )
    val _ = RunWithMouse[Model, Msg](program, (ev) => inputToMsg(ev), sub)
}
