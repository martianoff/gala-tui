func TestMegaCopySelectedAddsToast(t T) T {
    val m0 = NewMegaModel()
    val (m1, _) = MegaUpdate(m0, MegaCopySelected())
    return IsTrue(t, m1.Toasts.Length() > m0.Toasts.Length())
}

func TestMegaCopySelectedAppendsLog(t T) T {
    val m0 = NewMegaModel()
    val (m1, _) = MegaUpdate(m0, MegaCopySelected())
    return IsTrue(t, m1.Logs.Length() > m0.Logs.Length())
}

// ----------------------------------------------------------------------------
// View — every screen renders without crashing and produces recognisable
// content. These also catch regressions where the body collapses to empty.
// ----------------------------------------------------------------------------

func TestMegaRendersBuildsScreen(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "builds"))
    var buf = NewBuffer(120, 30)
    RenderTo(MegaView(m1), Rect(X = 0, Y = 0, Width = 120, Height = 30), buf)
    val joined = megaStitchRows(buf)
    return IsTrue(t, megaStringHas(joined, "Branch"))
}

func TestMegaRendersPipelinesScreen(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "pipelines"))
    var buf = NewBuffer(120, 30)
    RenderTo(MegaView(m1), Rect(X = 0, Y = 0, Width = 120, Height = 30), buf)
    val joined = megaStitchRows(buf)
    return IsTrue(t, megaStringHas(joined, "backend"))
}

func TestMegaRendersLogsScreen(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "logs"))
    var buf = NewBuffer(120, 30)
    RenderTo(MegaView(m1), Rect(X = 0, Y = 0, Width = 120, Height = 30), buf)
    val joined = megaStitchRows(buf)
    return IsTrue(t, megaStringHas(joined, "dashboard started"))
}

func TestMegaRendersConfirmModal(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaShowConfirm(Action = "Deploy to Prod"))
    var buf = NewBuffer(120, 30)
    RenderTo(MegaView(m1), Rect(X = 0, Y = 0, Width = 120, Height = 30), buf)
    val joined = megaStitchRows(buf)
    return IsTrue(t, megaStringHas(joined, "Deploy to Prod"))
}

func TestMegaRendersLogDrawerOverlay(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaToggleLogs())
    var buf = NewBuffer(120, 30)
    RenderTo(MegaView(m1), Rect(X = 0, Y = 0, Width = 120, Height = 30), buf)
    val joined = megaStitchRows(buf)
    // The overlay should still show the dashboard background plus a log line.
    return IsTrue(t, megaStringHas(joined, "dashboard started"))
}

func TestMegaRendersToastWhenPushed(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaShowConfirm(Action = "deploy"))
    val (m2, _) = MegaUpdate(m1, MegaConfirmYes())
    var buf = NewBuffer(120, 30)
    RenderTo(MegaView(m2), Rect(X = 0, Y = 0, Width = 120, Height = 30), buf)
    val joined = megaStitchRows(buf)
    return IsTrue(t, megaStringHas(joined, "Confirmed"))
}

// ----------------------------------------------------------------------------
// Helpers
// ----------------------------------------------------------------------------

func themesEqual(a MegaTheme, b MegaTheme) bool =
    megaThemeName(a) == megaThemeName(b)

func megaStitchRows(buf *Buffer) string {
    var s = ""
    var y = 0
    for y < buf.Height {
        s = s + BufferText(buf, y) + "\n"
        y = y + 1
    }
    return s
}

func megaStringHas(hay string, needle string) bool {
    val h = megaTestRunes(hay)
    val n = megaTestRunes(needle)
    val hn = h.Length()
    val nn = n.Length()
    if nn == 0 { return true }
    if nn > hn { return false }
    var i = 0
    for i <= hn - nn {
        var j = 0
        var ok = true
        for j < nn {
            if h.Get(i + j) != n.Get(j) {
                ok = false
                j = nn
            } else {
                j = j + 1
            }
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

func megaTestRunes(s string) Array[rune] {
    var acc = EmptyArray[rune]()
    for _, c := range s {
        acc = acc.Append(c)
    }
    return acc
}

func megaIsQuitMsg(msg MegaMsg) bool {
    return msg match {
        case MegaQuit() => true
        case _          => false
    }
}

// megaCmdHasMsg returns true if the cmd carries at least one inline message
// (the palette dispatches its action via `MsgCmd`, which we want to verify).
func megaCmdHasMsg(cmd Cmd[MegaMsg]) bool = !PendingMsgs(cmd).IsEmpty()

// megaUniqueLength counts distinct strings in `xs` — used to assert the
// theme cycle covers all four themes.
func megaUniqueLength(xs Array[string]) int {
    var uniq = EmptyArray[string]()
    var i = 0
    val n = xs.Length()
    for i < n {
        val s = xs.Get(i)
        var seen = false
        var j = 0
        val k = uniq.Length()
        for j < k {
            if uniq.Get(j) == s { seen = true; j = k }
            else { j = j + 1 }
        }
        if !seen { uniq = uniq.Append(s) }
        i = i + 1
    }
    return uniq.Length()
}
