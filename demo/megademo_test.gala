    val isNoOp = msg match {
        case MegaNoOp() => true
        case _          => false
    }
    return IsTrue(t, isNoOp)
}

// End-to-end: on the builds screen, scrolling the wheel drives the
// table cursor (when focus = table). This proves the mouse → KeyDown
// adapter wires through all the way to the table's update logic.
func TestMegaScrollDownAdvancesTableOnBuildsScreen(t T) T {
    val (mBuilds, _)  = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "builds"))
    val (mFocused, _) = MegaUpdate(mBuilds, MegaFocusNext())  // sidebar → table
    val before = mFocused.BuildsTable.Selected
    val scroll = MegaInputToMsg(MouseInput(Ev = MouseEvent(
        Btn = MouseScrollDown(), X = 0, Y = 0, Pressed = true,
    )))
    val (mScrolled, _) = MegaUpdate(mFocused, scroll)
    return IsTrue(t, mScrolled.BuildsTable.Selected > before)
}

