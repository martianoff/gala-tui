package main

import (
    . "github.com/martianoff/gala-tui"
    "github.com/martianoff/gala-tui/harness"
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/test"
)

// ============================================================================
// MegaDemo update-logic tests.
//
// Verifies the keyboard-routing behaviors that are easy to break — especially
// arrows, which should cause *visible* state change regardless of which pane
// has focus on which screen.
// ============================================================================

// Sidebar focus is the default, so ↓ moves the *tentative* sidebar
// cursor (SidebarSel). The active screen does NOT change until Enter.
func TestMegaArrowDownMovesSidebarCursor(t T) T {
    val m0 = NewMegaModel()
    val (m1, _) = MegaUpdate(m0, MegaKeyDown())
    val t1 = Eq(t, m0.SidebarSel, 0)
    val t2 = Eq(t1, m1.SidebarSel, 1)
    return Eq(t2, m1.Screens.Current(), "overview")  // screen unchanged
}

func TestMegaArrowUpWrapsSidebarToLastEntry(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaKeyUp())
    val t1 = Eq(t, m1.SidebarSel, 3)  // 4 entries: 0..3 → wraps to 3
    return Eq(t1, m1.Screens.Current(), "overview")
}

// Pressing Enter with focus = sidebar commits the cursor and jumps.
func TestMegaEnterOnSidebarJumps(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaKeyDown())   // SidebarSel = 1 (Builds)
    val (m2, _) = MegaUpdate(m1, MegaKeyEnter())
    return Eq(t, m2.Screens.Current(), "builds")
}

// On the builds screen with focus = table, ↓ moves the DataTable cursor.
func TestMegaArrowOnBuildsScreenWithTableFocusMovesCursor(t T) T {
    val (mBuilds, _) = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "builds"))
    val (mFocused, _) = MegaUpdate(mBuilds, MegaFocusNext())  // sidebar → table
    val before = mFocused.BuildsTable.Selected
    val (mDown, _) = MegaUpdate(mFocused, MegaKeyDown())
    return IsTrue(t, mDown.BuildsTable.Selected > before)
}

// On the pipelines screen with focus = table, ↓ moves the tree cursor.
func TestMegaArrowOnPipelinesScreenWithTableFocusMovesTreeCursor(t T) T {
    val (mPipes, _)   = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "pipelines"))
    val (mFocused, _) = MegaUpdate(mPipes, MegaFocusNext())  // sidebar → table
    val before = mFocused.PipelinesCursor
    val (mDown, _) = MegaUpdate(mFocused, MegaKeyDown())
    return IsTrue(t, mDown.PipelinesCursor > before)
}

func TestMegaPipelinesCursorClampsAtBottom(t T) T {
    val (mPipes, _)   = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "pipelines"))
    val (mFocused, _) = MegaUpdate(mPipes, MegaFocusNext())
    var m = mFocused
    var i = 0
    for i < 50 {
        val (mNext, _) = MegaUpdate(m, MegaKeyDown())
        m = mNext
        i = i + 1
    }
    val total = TreeFlatRowCount(m.Pipelines)
    return Eq(t, m.PipelinesCursor, total - 1)
}

// Without focus on table, arrows on pipelines do nothing (sidebar focus
// owns them — cycling SidebarSel instead).
func TestMegaArrowOnPipelinesScreenWithSidebarFocusNoOpOnTree(t T) T {
    val (mPipes, _) = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "pipelines"))
    val before = mPipes.PipelinesCursor
    val (mDown, _) = MegaUpdate(mPipes, MegaKeyDown())
    return Eq(t, mDown.PipelinesCursor, before)
}

// Enter on the pipelines tree toggles expand/collapse at the cursor.
func TestMegaEnterOnPipelinesTreeTogglesExpand(t T) T {
    val (mPipes, _)   = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "pipelines"))
    val (mFocused, _) = MegaUpdate(mPipes, MegaFocusNext())  // → table focus
    // Cursor 0 = root "Pipelines" (expanded by default). Enter collapses it.
    val rowsBefore = TreeFlatRowCount(mFocused.Pipelines)
    val (mCollapsed, _) = MegaUpdate(mFocused, MegaKeyEnter())
    val rowsAfter = TreeFlatRowCount(mCollapsed.Pipelines)
    return IsTrue(t, rowsAfter < rowsBefore)
}

// Space mirrors Enter for tree-toggle ergonomics.
func TestMegaSpaceOnPipelinesTreeTogglesExpand(t T) T {
    val (mPipes, _)   = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "pipelines"))
    val (mFocused, _) = MegaUpdate(mPipes, MegaFocusNext())
    val rowsBefore = TreeFlatRowCount(mFocused.Pipelines)
    // Space is decoded as MegaKeyEnter in MegaKeyToMsg.
    val msg = MegaKeyToMsg(PlainKey(Space()))
    val (mToggled, _) = MegaUpdate(mFocused, msg)
    val rowsAfter = TreeFlatRowCount(mToggled.Pipelines)
    return IsTrue(t, rowsAfter < rowsBefore)
}

// Enter on builds with focus = table copies the row (toast + log).
func TestMegaEnterOnBuildsTableCopiesRow(t T) T {
    val (mBuilds, _)  = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "builds"))
    val (mFocused, _) = MegaUpdate(mBuilds, MegaFocusNext())  // → table focus
    val toastsBefore = mFocused.Toasts.Length()
    val (mAfter, _) = MegaUpdate(mFocused, MegaKeyEnter())
    return IsTrue(t, mAfter.Toasts.Length() > toastsBefore)
}

// TreeToggleAt on a leaf node is a no-op visually (no children to expand).
func TestTreeToggleAtLeafDoesNotChangeFlatRowCount(t T) T {
    val tree = NewTreeBranchExpanded("root", ArrayOf[TreeNode](
        NewTreeLeaf("a"),
        NewTreeLeaf("b"),
    ))
    val before = TreeFlatRowCount(tree)
    val toggled = TreeToggleAt(tree, 1)  // leaf "a"
    val after = TreeFlatRowCount(toggled)
    return Eq(t, after, before)
}

// ----------------------------------------------------------------------------
// Regression tests for user-reported issues.
//
// Every bug the user reported gets a test here so we can't silently
// re-introduce the same UX regression.
// ----------------------------------------------------------------------------

// "When Nav is focused arrows don't do anything" — the sidebar must
// react to arrow keys and produce visible state change.
func TestRegressionSidebarFocusedArrowMovesCursor(t T) T {
    val m0 = NewMegaModel()
    val t1 = Eq(t, m0.Focus.Current(), "sidebar")  // default focus
    val (m1, _) = MegaUpdate(m0, MegaKeyDown())
    return IsTrue(t1, m1.SidebarSel != m0.SidebarSel)
}

// "Navigation is still a problem ... no action on arrows in table view" —
// the focus ring used to include "palette", a dead pane that swallowed
// Tab. Now Tab from "table" returns straight to "sidebar".
func TestRegressionFocusRingIsExactlySidebarAndTable(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaFocusNext())   // sidebar → table
    val t1 = Eq(t, m1.Focus.Current(), "table")
    val (m2, _) = MegaUpdate(m1, MegaFocusNext())                // table → sidebar
    return Eq(t1, m2.Focus.Current(), "sidebar")
}

// On the builds screen with focus = table, ↓ must drive the table cursor.
// (User saw nothing happen because focus was on the dead "palette" pane.)
func TestRegressionTableFocusArrowMovesBuildsCursor(t T) T {
    val (mBuilds, _)  = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "builds"))
    val (mFocused, _) = MegaUpdate(mBuilds, MegaFocusNext())  // → table focus
    val before = mFocused.BuildsTable.Selected
    val (mDown, _) = MegaUpdate(mFocused, MegaKeyDown())
    return IsTrue(t, mDown.BuildsTable.Selected > before)
}

// On the builds screen with focus = table, Enter must do something
// (copy the row).
func TestRegressionTableFocusEnterTriggersAction(t T) T {
    val (mBuilds, _)  = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "builds"))
    val (mFocused, _) = MegaUpdate(mBuilds, MegaFocusNext())
    val toastsBefore = mFocused.Toasts.Length()
    val (mAfter, _) = MegaUpdate(mFocused, MegaKeyEnter())
    return IsTrue(t, mAfter.Toasts.Length() > toastsBefore)
}

// "Tree expand/collapse — tried Enter and Space, neither worked."
// Enter on the pipelines tree must change the visible row count.
func TestRegressionTreeEnterTogglesExpand(t T) T {
    val (mPipes, _)   = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "pipelines"))
    val (mFocused, _) = MegaUpdate(mPipes, MegaFocusNext())
    val rowsBefore = TreeFlatRowCount(mFocused.Pipelines)
    val (mToggled, _) = MegaUpdate(mFocused, MegaKeyEnter())
    val rowsAfter = TreeFlatRowCount(mToggled.Pipelines)
    return IsTrue(t, rowsAfter != rowsBefore)
}

func TestRegressionTreeSpaceTogglesExpand(t T) T {
    val (mPipes, _)   = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "pipelines"))
    val (mFocused, _) = MegaUpdate(mPipes, MegaFocusNext())
    val rowsBefore = TreeFlatRowCount(mFocused.Pipelines)
    val msg = MegaKeyToMsg(PlainKey(Space()))
    val (mToggled, _) = MegaUpdate(mFocused, msg)
    val rowsAfter = TreeFlatRowCount(mToggled.Pipelines)
    return IsTrue(t, rowsAfter != rowsBefore)
}

// "Focus doesn't work in datatable (no visualization)" — render a focused
// DataTable and assert the cursor row uses BrightYellow foreground; an
// unfocused render must not.
func TestRegressionDataTableFocusedCursorPaintsBrightYellow(t T) T {
    val dt = NewDataTable(
        ArrayOf[string]("col"),
        ArrayOf[Constraint](Fill(1)),
        ArrayOf[Array[string]](ArrayOf[string]("hello")),
    )
    val buf = NewBuffer(20, 4)
    RenderTo(DataTableView(dt, true),
        Rect(X = 0, Y = 0, Width = 20, Height = 4), buf)
    // Row 0 = header, row 1 = horizontal rule, row 2 = data.
    return IsTrue(t, ColorEq(buf.StyleAt(0, 2).Fg, BrightYellow()))
}

func TestRegressionDataTableUnfocusedCursorIsNotBrightYellow(t T) T {
    val dt = NewDataTable(
        ArrayOf[string]("col"),
        ArrayOf[Constraint](Fill(1)),
        ArrayOf[Array[string]](ArrayOf[string]("hello")),
    )
    val buf = NewBuffer(20, 4)
    RenderTo(DataTableView(dt, false),
        Rect(X = 0, Y = 0, Width = 20, Height = 4), buf)
    return IsFalse(t, ColorEq(buf.StyleAt(0, 2).Fg, BrightYellow()))
}

// "Same thing in tree view" — TreeFocused must visibly highlight the
// cursor row when focused.
func TestRegressionTreeFocusedHighlightsCursorBrightYellow(t T) T {
    val tree = NewTreeBranchExpanded("root", ArrayOf[TreeNode](
        NewTreeLeaf("alpha"),
        NewTreeLeaf("beta"),
    ))
    val buf = NewBuffer(20, 4)
    RenderTo(TreeFocused(tree, 1, true),
        Rect(X = 0, Y = 0, Width = 20, Height = 4), buf)
    // Cursor at flat row 1 — that's "  • alpha" inside the expanded root.
    return IsTrue(t, ColorEq(buf.StyleAt(2, 1).Fg, BrightYellow()))
}

func TestRegressionTreeFocusedUnfocusedCursorIsNotBrightYellow(t T) T {
    val tree = NewTreeBranchExpanded("root", ArrayOf[TreeNode](
        NewTreeLeaf("alpha"),
        NewTreeLeaf("beta"),
    ))
    val buf = NewBuffer(20, 4)
    RenderTo(TreeFocused(tree, 1, false),
        Rect(X = 0, Y = 0, Width = 20, Height = 4), buf)
    return IsFalse(t, ColorEq(buf.StyleAt(2, 1).Fg, BrightYellow()))
}

// "Arrows and Enter don't do anything in the table view" — verify in
// the *rendered* output, not just the model: render the builds view,
// press ↓, render again, assert the bright-yellow cursor row moved
// down. This is the test that would have caught the per-render filter
// reset bug.
func TestRegressionBuildsCursorVisiblyMovesOnArrowDown(t T) T {
    val (mBuilds, _)  = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "builds"))
    val (mFocused, _) = MegaUpdate(mBuilds, MegaFocusNext())  // → table focus

    val w = 100
    val h = 24

    // Render the *whole* megademo body for the builds screen, then find
    // the y of the first row containing a bright-yellow-styled cell.
    // Skip past the demo's header (3 rows), border (1), tabs header
    // (1) — the table data rows start around y=7. Pass 7 as startY so
    // we find the table cursor, not the focused tab header.
    val tableStartY = 7

    val buf1 = NewBuffer(w, h)
    RenderTo(MegaView(mFocused), Rect(X = 0, Y = 0, Width = w, Height = h), buf1)
    val firstRow = megaFindBrightYellowRowAfter(buf1, w, h, tableStartY)

    val (mDown, _) = MegaUpdate(mFocused, MegaKeyDown())
    val buf2 = NewBuffer(w, h)
    RenderTo(MegaView(mDown), Rect(X = 0, Y = 0, Width = w, Height = h), buf2)
    val secondRow = megaFindBrightYellowRowAfter(buf2, w, h, tableStartY)

    val t1 = IsTrue(t, firstRow >= 0)            // we found a cursor row
    val t2 = IsTrue(t1, secondRow >= 0)
    return IsTrue(t2, secondRow > firstRow)      // cursor advanced visibly
}

// "Tree expand/collapse — tried Enter and Space, neither worked" —
// verify in the rendered output that pressing Enter on the pipelines
// tree actually changes the visible row count.
func TestRegressionTreeEnterChangesRenderedRowCount(t T) T {
    val (mPipes, _)   = MegaUpdate(NewMegaModel(), MegaPushScreen(Route = "pipelines"))
    val (mFocused, _) = MegaUpdate(mPipes, MegaFocusNext())

    val w = 100
    val h = 24

    val buf1 = NewBuffer(w, h)
    RenderTo(MegaView(mFocused), Rect(X = 0, Y = 0, Width = w, Height = h), buf1)
    val occupiedBefore = megaCountNonBlankRowsInTreePane(buf1, w, h)

    val (mToggled, _) = MegaUpdate(mFocused, MegaKeyEnter())
    val buf2 = NewBuffer(w, h)
    RenderTo(MegaView(mToggled), Rect(X = 0, Y = 0, Width = w, Height = h), buf2)
    val occupiedAfter = megaCountNonBlankRowsInTreePane(buf2, w, h)

    return IsTrue(t, occupiedBefore != occupiedAfter)
}

// Sidebar's "(Enter to jump)" hint shows only when sidebar is focused.
func TestRegressionSidebarFocusedShowsHint(t T) T {
    var buf = NewBuffer(60, 30)
    RenderTo(MegaView(NewMegaModel()),
        Rect(X = 0, Y = 0, Width = 60, Height = 30), buf)
    val joined = megaStitchRows(buf)
    return IsTrue(t, megaStringHas(joined, "Enter to jump"))
}

func TestRegressionSidebarUnfocusedHidesHint(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaFocusNext())  // → table
    var buf = NewBuffer(60, 30)
    RenderTo(MegaView(m1), Rect(X = 0, Y = 0, Width = 60, Height = 30), buf)
    val joined = megaStitchRows(buf)
    return IsFalse(t, megaStringHas(joined, "Enter to jump"))
}

// ----------------------------------------------------------------------------
// RunSequence + Snapshot integration tests.
//
// These drive the *whole* megademo through the harness — including the
// MegaInputToMsg adapter, runtime synchronous re-dispatch, and Render
// — and assert on the rendered output. This is what Layer 2 of the
// testing doc looks like in practice; if the user's "press Tab then ↓"
// flow stops working at any point in the pipeline, these tests fail.
// ----------------------------------------------------------------------------

// Build a fresh Harness for the megademo. Used by every RunSequence
// test below.
func newMegaHarness() harness.Harness[MegaModel, MegaMsg] {
    val program = Program[MegaModel, MegaMsg](
        Initial = NewMegaModel(),
        Update  = (m, msg) => MegaUpdate(m, msg),
        View    = (m) => MegaView(m),
    )
    return harness.NewHarnessFull[MegaModel, MegaMsg](program, (ev) => MegaInputToMsg(ev), 100, 24)
}

// Drive: Down (sidebar cursor 0→1) → Enter → land on builds with focus
// already on table. Then ↓ → table cursor advances. Snapshot the
// rendered text — assert the build #4208 row carries the bright cursor.
func TestHarnessDriveSidebarToBuildsThenScrollTable(t T) T {
    val final = newMegaHarness().RunSequence(ArrayOf[harness.HarnessStep[MegaMsg]](
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),    // sidebar cursor 0 → 1 (Builds)
        harness.StepKey[MegaMsg](Ev = PlainKey(Enter())),   // jump → focus auto-shifts to "table"
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),    // table cursor 0 → 1 ("#4208 …")
    ))
    val t1 = Eq(t, final.Model.Screens.Current(), "builds")
    val t2 = Eq(t1, final.Model.Focus.Current(), "table")
    val t3 = Eq(t2, final.Model.BuildsTable.Selected, 1)
    return IsTrue(t3, final.Contains("feat/mega-dashboard"))
}

// Drive: Down Down (sidebar 0→2 = Pipelines) → Enter → focus on table
// → Enter → tree collapses ("Pipelines" branch is at cursor 0). Snapshot
// proves the children disappeared from the rendered output.
func TestHarnessDrivePipelinesAndCollapseTree(t T) T {
    val final = newMegaHarness().RunSequence(ArrayOf[harness.HarnessStep[MegaMsg]](
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),    // sidebar 0 → 2 (Pipelines)
        harness.StepKey[MegaMsg](Ev = PlainKey(Enter())),   // jump
        harness.StepKey[MegaMsg](Ev = PlainKey(Enter())),   // collapse the root
    ))
    val t1 = Eq(t, final.Model.Screens.Current(), "pipelines")
    val collapsedRoot = !final.Model.Pipelines.Expanded
    val t2 = IsTrue(t1, collapsedRoot)
    // After collapse the rendered tree shouldn't show "backend".
    return IsFalse(t2, final.Contains("backend"))
}

// Drive: Ctrl-P → palette opens → Type "deploy" → arrow filters down to
// Deploy actions → Enter dispatches MegaShowConfirm. Snapshot shows the
// confirm modal.
func TestHarnessDrivePaletteToDeployConfirm(t T) T {
    val final = newMegaHarness().RunSequence(ArrayOf[harness.HarnessStep[MegaMsg]](
        harness.StepKey[MegaMsg](Ev = Ctrl(Char('p'))),
        harness.StepType[MegaMsg](Text = "deploy"),
        harness.StepKey[MegaMsg](Ev = PlainKey(Enter())),
    ))
    val t1 = IsFalse(t, final.Model.PaletteOpen)
    val t2 = IsTrue(t1, final.Model.ConfirmAction != "")
    return IsTrue(t2, final.Contains("Confirm action"))
}

// Drive: Down → Down → Down → Down (sidebar wraps to 0 = Overview) →
// Enter. The wraparound is the contract; this catches accidental
// off-by-one drifts in megaMoveSidebarSel.
func TestHarnessSidebarWrapsAround(t T) T {
    val final = newMegaHarness().RunSequence(ArrayOf[harness.HarnessStep[MegaMsg]](
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),    // wraps 3 → 0
        harness.StepKey[MegaMsg](Ev = PlainKey(Enter())),
    ))
    return Eq(t, final.Model.Screens.Current(), "overview")
}

// `Trace` exposes the Session AFTER each step, so a test can assert on
// intermediate frames. Verify the sidebar hint changes as focus moves.
func TestHarnessTraceShowsSidebarHintAfterFocusShift(t T) T {
    val trace = newMegaHarness().Trace(ArrayOf[harness.HarnessStep[MegaMsg]](
        harness.StepKey[MegaMsg](Ev = PlainKey(Tab())),     // sidebar → table
    ))
    val initial = trace.Get(0)
    val afterTab = trace.Get(1)
    val t1 = IsTrue(t, initial.Contains("Enter to jump"))      // sidebar focused
    return IsFalse(t1, afterTab.Contains("Enter to jump"))     // table focused
}

// Mouse input — drive the wheel through RunSequence. On the builds
// screen with table focus, scroll-down advances the row cursor.
//
// `StepScroll(X, Y, Up = false)` translates to a scroll-wheel-down
// MouseEvent, runs through MegaInputToMsg (which maps wheel events to
// up/down keys), then through update().
func TestHarnessMouseScrollAdvancesBuildsCursor(t T) T {
    val final = newMegaHarness().RunSequence(ArrayOf[harness.HarnessStep[MegaMsg]](
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),       // sidebar 0 → 1
        harness.StepKey[MegaMsg](Ev = PlainKey(Enter())),      // jump to builds
        harness.StepScroll[MegaMsg](X = 0, Y = 0, Up = false), // wheel down
    ))
    return Eq(t, final.Model.BuildsTable.Selected, 1)
}

// Mouse-click on the demo is currently a no-op (no hit-testing yet —
// the megademo treats clicks as MegaNoOp). This test documents that
// contract: clicking shouldn't crash and shouldn't advance the cursor.
func TestHarnessMouseClickIsNoOpToday(t T) T {
    val before = newMegaHarness().RunSequence(ArrayOf[harness.HarnessStep[MegaMsg]](
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),
        harness.StepKey[MegaMsg](Ev = PlainKey(Enter())),
    ))
    val after = before.Click(40, 10)
    return Eq(t, after.Model.BuildsTable.Selected, before.Model.BuildsTable.Selected)
}

// Resize through the harness — pass StepResize through the input
// adapter, verify the model isn't disturbed (resize is a no-op for
// the megademo since View() re-queries TermSize on each frame).
func TestHarnessResizeDoesNotDisturbModel(t T) T {
    val final = newMegaHarness().RunSequence(ArrayOf[harness.HarnessStep[MegaMsg]](
        harness.StepKey[MegaMsg](Ev = PlainKey(Down())),
        harness.StepKey[MegaMsg](Ev = PlainKey(Enter())),
        harness.StepResize[MegaMsg](W = 200, H = 60),
    ))
    return Eq(t, final.Model.Screens.Current(), "builds")
}

// ----------------------------------------------------------------------------
// Snapshot fixture tests — RunSequence + Snapshot together. Compare
// the rendered text against a golden-file string. Catches *visual*
// regressions: layout shifts, missing cells, wrong styles in plaintext.
// ----------------------------------------------------------------------------

// Tiny program for snapshot tests — a Counter, the simplest possible
// thing you can render and assert on byte-for-byte.
struct CounterModel(N int)
sealed type CounterMsg {
    case CounterInc()
    case CounterDec()
}

func counterUpdate(m CounterModel, msg CounterMsg) Tuple[CounterModel, Cmd[CounterMsg]] =
    msg match {
        case CounterInc() => (m.Copy(N = m.N + 1), NoCmd[CounterMsg]())
        case CounterDec() => (m.Copy(N = m.N - 1), NoCmd[CounterMsg]())
    }

func counterView(m CounterModel) Widget {
    val title = TextStyled(s" Count: ${m.N} ",
        DefaultStyle().WithBold().WithFg(BrightCyan()))
    val hint = TextStyled(" + / - to change ", DefaultStyle().WithDim())
    return Column(ArrayOf[LayoutChild](
        Fixed(1, title),
        Fixed(1, hint),
    ))
}

func counterKey(ev KeyEvent) CounterMsg {
    return ev.Key match {
        case Char(c)     => counterCharToMsg(c)
        case Esc()       => CounterInc()  // ignored in tests
        case _           => CounterInc()
    }
}

func counterCharToMsg(c rune) CounterMsg {
    if c == '+' || c == '=' { return CounterInc() }
    if c == '-' { return CounterDec() }
    return CounterInc()
}

// RunSequence + Snapshot golden-file pattern: drive a sequence of
// inputs, then assert the final rendered text matches a fixture. If
// the layout shifts, this test fails with a clear before/after diff.
func TestHarnessSnapshotMatchesAfterRunSequence(t T) T {
    val program = Program[CounterModel, CounterMsg](
        Initial = CounterModel(N = 0),
        Update  = (m, msg) => counterUpdate(m, msg),
        View    = (m) => counterView(m),
    )
    val h = harness.NewHarness[CounterModel, CounterMsg](program, (ev) => counterKey(ev), 25, 2)
    val final = h.RunSequence(ArrayOf[harness.HarnessStep[CounterMsg]](
        harness.StepType[CounterMsg](Text = "+++"),
    ))
    val want = " Count: 3                " + "\n" +
               " + / - to change         "
    val got = final.Text()
    return IsTrue(t, SnapshotsEqual(got, want))
}

// SnapshotDiff reports the row-level mismatch when two snapshots
// don't match — useful inside test assertions for actionable error
// messages rather than "expected true got false".
func TestHarnessSnapshotDiffReportsRow(t T) T {
    val program = Program[CounterModel, CounterMsg](
        Initial = CounterModel(N = 0),
        Update  = (m, msg) => counterUpdate(m, msg),
        View    = (m) => counterView(m),
    )
    val h = harness.NewHarness[CounterModel, CounterMsg](program, (ev) => counterKey(ev), 25, 2)
    val s1 = h.RunSequence(ArrayOf[harness.HarnessStep[CounterMsg]](
        harness.StepType[CounterMsg](Text = "+"),
    ))
    val s2 = h.RunSequence(ArrayOf[harness.HarnessStep[CounterMsg]](
        harness.StepType[CounterMsg](Text = "++"),
    ))
    val diff = SnapshotDiff(s1.Text(), s2.Text())
    return IsTrue(t, diff.IsDefined())
}

// ----------------------------------------------------------------------------
// (test below is unrelated — kept original location.)
// ----------------------------------------------------------------------------

func TestTreeToggleAtBranchCollapsesChildren(t T) T {
    val tree = NewTreeBranchExpanded("root", ArrayOf[TreeNode](
        NewTreeBranchExpanded("inner", ArrayOf[TreeNode](
            NewTreeLeaf("leaf1"),
            NewTreeLeaf("leaf2"),
        )),
    ))
    val before = TreeFlatRowCount(tree)  // root + inner + 2 leaves = 4
    val toggled = TreeToggleAt(tree, 1)   // collapse "inner"
    val after = TreeFlatRowCount(toggled) // root + inner = 2
    return Eq(t, before - after, 2)
}

func TestMegaCtrlPOpensPalette(t T) T {
    val msg = MegaKeyToMsg(Ctrl(Char('p')))
    val isToggle = msg match {
        case MegaPalTogglePalette() => true
        case _                      => false
    }
    return IsTrue(t, isToggle)
}

func TestMegaArrowsInsidePaletteMoveSelection(t T) T {
    var m = NewMegaModel()
    val (mOpen, _) = MegaUpdate(m, MegaPalTogglePalette())
    val before = mOpen.Palette.Selected
    val (mNext, _) = MegaUpdate(mOpen, MegaKeyDown())
    return IsTrue(t, mNext.Palette.Selected != before)
}

func TestMegaQuitWorks(t T) T {
    val (_, cmd) = MegaUpdate(NewMegaModel(), MegaQuit())
    return IsTrue(t, IsQuit(cmd))
}

func TestMegaToggleHelp(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaToggleHelp())
    return IsTrue(t, m1.ShowHelp)
}

func TestMegaToggleLogs(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaToggleLogs())
    return IsTrue(t, m1.ShowLogs)
}

func TestMegaCycleTheme(t T) T {
    val m0 = NewMegaModel()
    val (m1, _) = MegaUpdate(m0, MegaCycleTheme())
    val themesDiffer = !themesEqual(m0.ActiveTheme, m1.ActiveTheme)
    return IsTrue(t, themesDiffer)
}

func TestMegaConfirmThenYes(t T) T {
    val (m1, _) = MegaUpdate(NewMegaModel(), MegaShowConfirm(Action = "deploy"))
    val confirming = m1.ConfirmAction != ""
    val t1 = IsTrue(t, confirming)
    val (m2, _) = MegaUpdate(m1, MegaConfirmYes())
    val cleared = m2.ConfirmAction == ""
    return IsTrue(t1, cleared)
}

// ----------------------------------------------------------------------------
// MegaInputToMsg adapter — keys, mouse, resize all funnel through one
// translator when the demo runs under RunFull.
