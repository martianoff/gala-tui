package gala_tui

import (
    . "martianoff/gala/collection_immutable"
)

// ============================================================================
// Developer-UX shortcuts. These exist purely to compress boilerplate the
// underlying framework already has but that every app would otherwise
// re-write by hand: spec-string-driven keymaps, one-call program runners.
//
// Nothing here adds new capability. Apps that want full control can keep
// using `Run` / `RunWithSub` / `RunWithMouse` directly with hand-written
// `keyToMsg` functions. The shortcuts collapse the *common* shape:
//
//     val km = DispatchKeys[Msg](ArrayOf[KeyBinding[Msg]](
//         KeyBind("ctrl+c", Quit()),
//         KeyBind("q",      Quit()),
//         KeyBind("+",      Inc()),
//         KeyBind("-",      Dec()),
//     ), Inc())  // fallback
//
//     val _ = RunSimple[Model, Msg](Model(N = 0), update, view, km)
//
// vs. the long form: 12+ lines for `keyToMsg` + 6 lines of `Program(...)`
// + Run construction.
// ============================================================================

// DispatchKeys turns a list of KeyBindings + a fallback message into a
// `func(KeyEvent) T` ready to feed into `Run` / `RunWithSub`. The first
// binding whose `Match` predicate fires wins; if no binding matches,
// returns the fallback.
//
// Pair with `KeyBind`, `KeyBindMake`, `Bind`, `BindCtrl`, `BindAny`,
// `BindWhere` to build the bindings list.
//
//     val keyToMsg = DispatchKeys[Msg](ArrayOf[KeyBinding[Msg]](
//         KeyBind("ctrl+c", Quit()),
//         KeyBind("q",      Quit()),
//         BindAny[Msg]((ev) => CharTyped(C = unwrapChar(ev.Key))),
//     ), NoOp())
func DispatchKeys[T any](bindings Array[KeyBinding[T]], fallback T) func(KeyEvent) T = (ev) => {
    val hit = bindings.Find((b) => b.Match(ev))
    return hit match {
        case Some(b) => b.Make(ev)
        case None()  => fallback
    }
}

// RunSimple bundles `Program(...)` construction with `Run(...)`. The
// most common shape — pure-keyboard app, no async cmds, no subs —
// collapses from 6 lines to one.
//
//     val _ = RunSimple[Model, Msg](
//         Model(N = 0), update, view, keyToMsg,
//     )
func RunSimple[M any, T any](
    initial M,
    update func(M, T) Tuple[M, Cmd[T]],
    view func(M) Widget,
    keyToMsg func(KeyEvent) T,
) M {
    val program = Program[M, T](Initial = initial, Update = update, View = view)
    return Run[M, T](program, keyToMsg)
}

// RunSimpleWithSub is `RunSimple` with a Sub — the common shape for apps
// that want a clock tick or another KeySub batched in.
//
//     val sub = TickSub[Msg](Interval = Milliseconds(100), Make = () => Tick())
//     val _ = RunSimpleWithSub[Model, Msg](initial, update, view, keyToMsg, sub)
func RunSimpleWithSub[M any, T any](
    initial M,
    update func(M, T) Tuple[M, Cmd[T]],
    view func(M) Widget,
    keyToMsg func(KeyEvent) T,
    sub Sub[T],
) M {
    val program = Program[M, T](Initial = initial, Update = update, View = view)
    return RunWithSub[M, T](program, keyToMsg, sub)
}

// RunSimpleRich is the deprecated alias for `RunSimpleWithSub`.
func RunSimpleRich[M any, T any](
    initial M,
    update func(M, T) Tuple[M, Cmd[T]],
    view func(M) Widget,
    keyToMsg func(KeyEvent) T,
    sub Sub[T],
) M = RunSimpleWithSub[M, T](initial, update, view, keyToMsg, sub)

// RunSimpleWithMouse is `RunSimple` for full-input apps (mouse + resize).
// The InputEvent → Msg adapter is `inputToMsg`. Apps that only care
// about keyboard events can use `LiftKeysToInput(keyToMsg)` to promote
// a keys-only handler.
//
//     val _ = RunSimpleWithMouse[Model, Msg](
//         initial, update, view,
//         (ev) => MyInputToMsg(ev),
//         tickSub,
//     )
func RunSimpleWithMouse[M any, T any](
    initial M,
    update func(M, T) Tuple[M, Cmd[T]],
    view func(M) Widget,
    inputToMsg func(InputEvent) T,
    sub Sub[T],
) M {
    val program = Program[M, T](Initial = initial, Update = update, View = view)
    return RunWithMouse[M, T](program, inputToMsg, sub)
}

// RunSimpleFull is the deprecated alias for `RunSimpleWithMouse`.
func RunSimpleFull[M any, T any](
    initial M,
    update func(M, T) Tuple[M, Cmd[T]],
    view func(M) Widget,
    inputToMsg func(InputEvent) T,
    sub Sub[T],
) M = RunSimpleWithMouse[M, T](initial, update, view, inputToMsg, sub)

// LiftKeysToInput promotes a `func(KeyEvent) T` to `func(InputEvent) T`,
// dispatching mouse/resize/unknown events through `mouse` / `fallback`.
// Saves apps from writing the InputEvent translator by hand when they
// only want to handle keys + scroll wheel.
//
//     val _ = RunSimpleWithMouse[Model, Msg](
//         initial, update, view,
//         LiftKeysToInput[Msg](keyToMsg, NoOp(), NoOp()),
//         sub,
//     )
//
// `mouse` is dispatched on every mouse event (click, scroll, motion);
// `fallback` covers resize and unknown-input. To handle scroll-wheel
// specifically, use `LiftKeysToInputScroll`.
func LiftKeysToInput[T any](
    keyToMsg func(KeyEvent) T,
    mouse T,
    fallback T,
) func(InputEvent) T = (ev) => ev match {
    case KeyInput(k)       => keyToMsg(k)
    case MouseInput(_)     => mouse
    case ResizeInput(_, _) => fallback
    case UnknownInput()    => fallback
}

// LiftKeyToInput is the deprecated alias for `LiftKeysToInput`.
func LiftKeyToInput[T any](
    keyToMsg func(KeyEvent) T,
    mouse T,
    fallback T,
) func(InputEvent) T = LiftKeysToInput[T](keyToMsg, mouse, fallback)

// LiftKeysToInputScroll is the most-common-mouse-shape lift: scroll-wheel
// up/down get routed to scroll-up/down messages; clicks and other mouse
// events get the `clickFallback`; resize/unknown get `fallback`.
//
//     val _ = RunSimpleWithMouse[Model, Msg](
//         initial, update, view,
//         LiftKeysToInputScroll[Msg](keyToMsg, ScrollUp(), ScrollDown(), NoOp(), NoOp()),
//         sub,
//     )
func LiftKeysToInputScroll[T any](
    keyToMsg func(KeyEvent) T,
    scrollUp T,
    scrollDown T,
    clickFallback T,
    fallback T,
) func(InputEvent) T = (ev) => ev match {
    case KeyInput(k)       => keyToMsg(k)
    case MouseInput(m)     => liftScroll[T](m, scrollUp, scrollDown, clickFallback)
    case ResizeInput(_, _) => fallback
    case UnknownInput()    => fallback
}

// LiftKeyToInputScroll is the deprecated alias for `LiftKeysToInputScroll`.
func LiftKeyToInputScroll[T any](
    keyToMsg func(KeyEvent) T,
    scrollUp T,
    scrollDown T,
    clickFallback T,
    fallback T,
) func(InputEvent) T = LiftKeysToInputScroll[T](
    keyToMsg, scrollUp, scrollDown, clickFallback, fallback,
)

func liftScroll[T any](m MouseEvent, up T, down T, fallback T) T = m.Btn match {
    case MouseScrollUp()   => up
    case MouseScrollDown() => down
    case MouseLeft()       => fallback
    case MouseMiddle()     => fallback
    case MouseRight()      => fallback
    case MouseButtonNone() => fallback
}
