package gala_tui

import (
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/test"
)

// ============================================================================
// Modal / dialog rendering tests.
// ============================================================================

func TestModalHasDimBackdrop(t T) T {
    val buf = NewBuffer(20, 10)
    RenderTo(Modal(10, 4, Text("hi")),
        Rect(X = 0, Y = 0, Width = 20, Height = 10), buf)
    // Top-left corner is backdrop (not masked by panel).
    return IsTrue(t, buf.StyleAt(0, 0).Dim)
}

func TestModalCentersPanelHorizontally(t T) T {
    val buf = NewBuffer(20, 6)
    RenderTo(Modal(10, 4, Text("hi")),
        Rect(X = 0, Y = 0, Width = 20, Height = 6), buf)
    // Panel is 10 wide in a 20-wide area → starts at col 5.
    return Eq(t, buf.CharAt(5, 1), '┌')
}

func TestConfirmDialogRendersBothButtons(t T) T {
    val buf = NewBuffer(40, 6)
    RenderTo(ConfirmDialog("Confirm", "Proceed?", true),
        Rect(X = 0, Y = 0, Width = 40, Height = 6), buf)
    val combined = catRows(buf)
    val t1 = IsTrue(t, substringPresent(combined, "Yes"))
    return IsTrue(t1, substringPresent(combined, "No"))
}

func TestAlertDialogRendersOK(t T) T {
    val buf = NewBuffer(30, 6)
    RenderTo(AlertDialog("Heads up", "All good."),
        Rect(X = 0, Y = 0, Width = 30, Height = 6), buf)
    val combined = catRows(buf)
    return IsTrue(t, substringPresent(combined, "OK"))
}

// ----------------------------------------------------------------------------
// Helpers (relocated from focus_modal_test.gala).
// ----------------------------------------------------------------------------

func catRows(buf *Buffer) string {
    var s = ""
    var y = 0
    for y < buf.Height {
        s = s + BufferText(buf, y) + "\n"
        y = y + 1
    }
    return s
}

func substringPresent(hay string, needle string) bool {
    val ha = toRuneArr(hay)
    val ne = toRuneArr(needle)
    val hn = ha.Length()
    val nn = ne.Length()
    if nn == 0 { return true }
    if nn > hn { return false }
    var i = 0
    for i <= hn - nn {
        var j = 0
        var ok = true
        for j < nn {
            if ha.Get(i + j) != ne.Get(j) {
                ok = false
                j = nn
            } else {
                j = j + 1
            }
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

func toRuneArr(s string) Array[rune] {
    var acc = EmptyArray[rune]()
    for _, c := range s {
        acc = acc.Append(c)
    }
    return acc
}
