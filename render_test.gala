package gala_tui

import (
    "strings"
    . "martianoff/gala/test"
)

// ============================================================================
// Color tests — verify SGR emission for every variant across fg and bg.
// ============================================================================

func TestColorDefaultSgr(t T) T {
    val t1 = Eq(t, ToSgrFg(DefaultColor()), "39")
    return Eq(t1, ToSgrBg(DefaultColor()), "49")
}

func TestColorNamedStandardSgr(t T) T {
    val t1 = Eq(t, ToSgrFg(Red()), "31")       // 30 + 1
    val t2 = Eq(t1, ToSgrBg(Red()), "41")      // 40 + 1
    val t3 = Eq(t2, ToSgrFg(White()), "37")    // 30 + 7
    return Eq(t3, ToSgrBg(Black()), "40")
}

func TestColorNamedBrightSgr(t T) T {
    val t1 = Eq(t, ToSgrFg(BrightRed()), "91")    // 90 + 1
    val t2 = Eq(t1, ToSgrBg(BrightRed()), "101")  // 100 + 1
    return Eq(t2, ToSgrFg(BrightWhite()), "97")
}

func TestColorIndexedSgr(t T) T {
    val t1 = Eq(t, ToSgrFg(Indexed(200)), "38;5;200")
    return Eq(t1, ToSgrBg(Indexed(0)), "48;5;0")
}

func TestColorRGBSgr(t T) T {
    val t1 = Eq(t, ToSgrFg(RGB(255, 128, 0)), "38;2;255;128;0")
    return Eq(t1, ToSgrBg(RGB(0, 0, 0)), "48;2;0;0;0")
}

func TestColorEq(t T) T {
    val t1 = IsTrue(t, ColorEq(Red(), Red()))
    val t2 = IsFalse(t1, ColorEq(Red(), Green()))
    return IsTrue(t2, ColorEq(RGB(10, 20, 30), RGB(10, 20, 30)))
}

// ============================================================================
// Style tests — fluent builders and SGR emission.
// ============================================================================

func TestDefaultStyleEmitsNothing(t T) T {
    return Eq(t, DefaultStyle().ToSgr(), "")
}

func TestStyleBoldEmits(t T) T {
    return Eq(t, DefaultStyle().WithBold().ToSgr(), "\x1b[1m")
}

func TestStyleFgEmits(t T) T {
    return Eq(t, DefaultStyle().WithFg(Red()).ToSgr(), "\x1b[31m")
}

func TestStyleFluentOrderIndependent(t T) T {
    val a = DefaultStyle().WithBold().WithFg(Red()).WithItalic()
    val b = DefaultStyle().WithItalic().WithFg(Red()).WithBold()
    // Attribute order in SGR is canonical (Bold;Italic;Fg), so two equivalent
    // styles produce IDENTICAL output regardless of builder-call order.
    return Eq(t, a.ToSgr(), b.ToSgr())
}

func TestStyleEqualIgnoresBuilderOrder(t T) T {
    val a = DefaultStyle().WithBold().WithFg(Red()).On(Black()).WithItalic().WithUnderline()
    val b = DefaultStyle().WithUnderline().WithItalic().On(Black()).WithFg(Red()).WithBold()
    return IsTrue(t, StyleEqual(a, b))
}

func TestStyleAllAttributes(t T) T {
    val s = DefaultStyle().
        WithBold().WithDim().WithItalic().WithUnderline().WithBlink().WithReverse().WithStrike().
        WithFg(RGB(1, 2, 3)).On(Indexed(42))
    val sgr = s.ToSgr()
    // Codes 1,2,3,4,5,7,9 must all appear before the fg/bg codes.
    val t1 = IsTrue(t, strings.Contains(sgr, "1;2;3;4;5;7;9"))
    val t2 = IsTrue(t1, strings.Contains(sgr, "38;2;1;2;3"))
    return IsTrue(t2, strings.Contains(sgr, "48;5;42"))
}

// ============================================================================
// Buffer tests — primitive ops and ANSI-rendering correctness.
//
// We compare single-rune values by rendering to a single-char string with
// `CellChar` — avoids an Immutable[rune] vs rune unification issue at the Eq
// call site (see BUG-gala_tui-009).
// ============================================================================

// CellChar renders the cell at (x, y) as a one-rune string. Uses the raw-rune
// accessor CharAt on Buffer to avoid Immutable[rune] unification issues inside
// Eq (see BUG-gala_tui-009).
func CellChar(b *Buffer, x int, y int) string = string(b.CharAt(x, y))

func TestNewBufferEmpty(t T) T {
    var b = NewBuffer(5, 3)
    val t1 = Eq(t, b.Width, 5)
    val t2 = Eq(t1, b.Height, 3)
    return Eq(t2, CellChar(b, 0, 0), " ")
}

func TestBufferSetGetRoundtrip(t T) T {
    var b = NewBuffer(4, 2)
    b.Set(2, 1, Cell(Ch = 'x', St = DefaultStyle().WithBold()))
    val t1 = Eq(t, CellChar(b, 2, 1), "x")
    return IsTrue(t1, b.StyleAt(2, 1).Bold)
}

func TestBufferSetOutOfBoundsIsNoOp(t T) T {
    var b = NewBuffer(2, 2)
    // None of these should panic or crash.
    b.Set(-1, 0, Cell(Ch = 'z', St = DefaultStyle()))
    b.Set(0, -1, Cell(Ch = 'z', St = DefaultStyle()))
    b.Set(2, 0, Cell(Ch = 'z', St = DefaultStyle()))
    b.Set(0, 2, Cell(Ch = 'z', St = DefaultStyle()))
    // The buffer must be unchanged.
    return Eq(t, CellChar(b, 0, 0), " ")
}

func TestBufferDrawText(t T) T {
    var b = NewBuffer(10, 1)
    val advanced = b.DrawText(0, 0, "Hello", DefaultStyle())
    val t1 = Eq(t, advanced, 5)
    val t2 = Eq(t1, CellChar(b, 0, 0), "H")
    return Eq(t2, CellChar(b, 4, 0), "o")
}

func TestBufferDrawTextClipsRight(t T) T {
    var b = NewBuffer(3, 1)
    val advanced = b.DrawText(0, 0, "Hello", DefaultStyle())
    // `advanced` equals the input length even when cells were clipped — the
    // return is "how many columns I wanted to occupy," not "how many I did."
    val t1 = Eq(t, advanced, 5)
    val t2 = Eq(t1, CellChar(b, 0, 0), "H")
    val t3 = Eq(t2, CellChar(b, 2, 0), "l")
    // Cell at x=3 would be out of bounds and was dropped silently.
    return Eq(t3, b.Width, 3)
}

func TestBufferFillRect(t T) T {
    var b = NewBuffer(5, 3)
    b.Fill(Rect(X = 1, Y = 1, Width = 2, Height = 1), Cell(Ch = '#', St = DefaultStyle()))
    val t1 = Eq(t, CellChar(b, 0, 0), " ")   // unchanged
    val t2 = Eq(t1, CellChar(b, 1, 1), "#")
    val t3 = Eq(t2, CellChar(b, 2, 1), "#")
    return Eq(t3, CellChar(b, 3, 1), " ")    // outside fill
}

func TestBufferFillZeroRectIsNoOp(t T) T {
    var b = NewBuffer(3, 3)
    b.Fill(Rect(X = 0, Y = 0, Width = 0, Height = 3), Cell(Ch = 'X', St = DefaultStyle()))
    return Eq(t, CellChar(b, 0, 0), " ")
}

func TestBufferCloneIsIndependent(t T) T {
    var b = NewBuffer(3, 1)
    b.DrawText(0, 0, "abc", DefaultStyle())
    val copy = b.Clone()
    b.Set(0, 0, Cell(Ch = 'Z', St = DefaultStyle()))
    val t1 = Eq(t, CellChar(b, 0, 0), "Z")
    return Eq(t1, CellChar(copy, 0, 0), "a")
}

func TestBufferEqual(t T) T {
    val a = NewBuffer(3, 1)
    var b = NewBuffer(3, 1)
    a.DrawText(0, 0, "abc", DefaultStyle())
    b.DrawText(0, 0, "abc", DefaultStyle())
    val t1 = IsTrue(t, a.ContentsEqual(b))
    b.Set(0, 0, Cell(Ch = 'z', St = DefaultStyle()))
    return IsFalse(t1, a.ContentsEqual(b))
}

func TestBufferStringPlain(t T) T {
    var b = NewBuffer(3, 1)
    b.DrawText(0, 0, "abc", DefaultStyle())
    val out = b.String()
    // Plain, no styling — just characters with a trailing reset.
    return Eq(t, out, "\x1b[0mabc\x1b[0m")
}

func TestBufferStringStyledRun(t T) T {
    var b = NewBuffer(5, 1)
    val red = DefaultStyle().WithFg(Red())
    b.DrawText(0, 0, "hello", red)
    val out = b.String()
    // Style change happens exactly once at the start of the row.
    val t1 = IsTrue(t, strings.Contains(out, "\x1b[31m"))
    // And resets trail the row.
    return IsTrue(t1, strings.HasSuffix(out, "\x1b[0m"))
}

func TestBufferStringMultilineSeparator(t T) T {
    var b = NewBuffer(2, 2)
    b.DrawText(0, 0, "ab", DefaultStyle())
    b.DrawText(0, 1, "cd", DefaultStyle())
    val out = b.String()
    // Two logical lines => one embedded newline.
    return Eq(t, strings.Count(out, "\n"), 1)
}

// ============================================================================
// Rect tests
// ============================================================================

func TestRectContains(t T) T {
    val r = Rect(X = 1, Y = 1, Width = 3, Height = 2)
    val t1 = IsTrue(t, r.Contains(1, 1))
    val t2 = IsTrue(t1, r.Contains(3, 2))
    val t3 = IsFalse(t2, r.Contains(0, 1))   // left of origin
    val t4 = IsFalse(t3, r.Contains(4, 1))   // past right edge
    return IsFalse(t4, r.Contains(1, 3))     // past bottom edge
}

func TestRectZero(t T) T {
    val t1 = IsTrue(t, Rect(X = 0, Y = 0, Width = 0, Height = 5).Zero())
    val t2 = IsTrue(t1, Rect(X = 0, Y = 0, Width = 5, Height = 0).Zero())
    return IsFalse(t2, Rect(X = 0, Y = 0, Width = 1, Height = 1).Zero())
}
