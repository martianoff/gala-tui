package gala_tui

import (
    . "martianoff/gala/collection_immutable"
    . "martianoff/gala/test"
)

// ============================================================================
// Markdown parsing + rendering tests.
// ============================================================================

// ----------------------------------------------------------------------------
// Block-level parser
// ----------------------------------------------------------------------------

func TestMarkdownHeading1(t T) T {
    val blocks = ParseMarkdown("# Hello")
    val t1 = Eq(t, blocks.Length(), 1)
    val isH1 = blocks.Get(0) match {
        case MdHeading(level, _) => level == 1
        case _                   => false
    }
    return IsTrue(t1, isH1)
}

func TestMarkdownHeading3(t T) T {
    val blocks = ParseMarkdown("### Small")
    val isH3 = blocks.Get(0) match {
        case MdHeading(level, _) => level == 3
        case _                   => false
    }
    return IsTrue(t, isH3)
}

func TestMarkdownParagraphCollectsLines(t T) T {
    val blocks = ParseMarkdown("line one\nline two")
    // Two non-blank lines should merge into one paragraph.
    val t1 = Eq(t, blocks.Length(), 1)
    val isPara = blocks.Get(0) match {
        case MdParagraph(_) => true
        case _              => false
    }
    return IsTrue(t1, isPara)
}

func TestMarkdownBlankLineSplitsParagraphs(t T) T {
    val blocks = ParseMarkdown("first para\n\nsecond para")
    // Expect paragraph, blank, paragraph → length 3 after we keep blanks.
    val paras = blocksOfKind(blocks, "paragraph")
    return Eq(t, paras, 2)
}

func TestMarkdownBullets(t T) T {
    val blocks = ParseMarkdown("- alpha\n- beta\n- gamma")
    val bullets = blocksOfKind(blocks, "bullet")
    return Eq(t, bullets, 3)
}

func TestMarkdownNumberedLists(t T) T {
    val blocks = ParseMarkdown("1. first\n2. second\n3. third")
    val nums = blocksOfKind(blocks, "numbered")
    return Eq(t, nums, 3)
}

func TestMarkdownHorizontalRule(t T) T {
    val blocks = ParseMarkdown("above\n\n---\n\nbelow")
    val rules = blocksOfKind(blocks, "rule")
    return Eq(t, rules, 1)
}

// ----------------------------------------------------------------------------
// Inline parser
// ----------------------------------------------------------------------------

func TestMarkdownBoldInline(t T) T {
    val inlines = parseInlines("hello **world** end")
    val hasBold = anyInlineOfKind(inlines, "bold")
    return IsTrue(t, hasBold)
}

func TestMarkdownItalicWithUnderscore(t T) T {
    val inlines = parseInlines("see _this_ word")
    val hasItalic = anyInlineOfKind(inlines, "italic")
    return IsTrue(t, hasItalic)
}

func TestMarkdownItalicWithStar(t T) T {
    val inlines = parseInlines("see *this* word")
    val hasItalic = anyInlineOfKind(inlines, "italic")
    return IsTrue(t, hasItalic)
}

func TestMarkdownInlineCode(t T) T {
    val inlines = parseInlines("call `fmt.Println` here")
    val hasCode = anyInlineOfKind(inlines, "code")
    return IsTrue(t, hasCode)
}

func TestMarkdownLinkParsed(t T) T {
    val inlines = parseInlines("see [docs](https://example.com) for more")
    val hasLink = anyInlineOfKind(inlines, "link")
    return IsTrue(t, hasLink)
}

func TestMarkdownUnmatchedStarIsLiteral(t T) T {
    val inlines = parseInlines("five * three")
    // No matching closing '*' — should stay as literal text.
    val onlyText = allInlinesText(inlines)
    return IsTrue(t, onlyText)
}

// ----------------------------------------------------------------------------
// Rendering
// ----------------------------------------------------------------------------

func TestMarkdownViewRendersHeading(t T) T {
    val widget = MarkdownView("# Dashboard")
    val buf = NewBuffer(20, 1)
    RenderTo(widget, Rect(X = 0, Y = 0, Width = 20, Height = 1), buf)
    return IsTrue(t, buf.StyleAt(0, 0).Bold)
}

func TestMarkdownViewHeading1IsCyan(t T) T {
    val widget = MarkdownView("# Title")
    val buf = NewBuffer(10, 1)
    RenderTo(widget, Rect(X = 0, Y = 0, Width = 10, Height = 1), buf)
    return IsTrue(t, ColorEq(buf.StyleAt(0, 0).Fg, BrightCyan()))
}

func TestMarkdownViewBoldInline(t T) T {
    val widget = MarkdownView("see **important** text")
    val buf = NewBuffer(30, 1)
    RenderTo(widget, Rect(X = 0, Y = 0, Width = 30, Height = 1), buf)
    // "see " → 4 cells, then "important" in bold starting at col 4.
    return IsTrue(t, buf.StyleAt(4, 0).Bold)
}

func TestMarkdownViewLinkUnderlined(t T) T {
    val widget = MarkdownView("go to [docs](https://example.com)")
    val buf = NewBuffer(30, 1)
    RenderTo(widget, Rect(X = 0, Y = 0, Width = 30, Height = 1), buf)
    // "go to " → 6 cells, then "docs" with underline.
    return IsTrue(t, buf.StyleAt(6, 0).Underline)
}

func TestMarkdownViewBulletHasDotPrefix(t T) T {
    val widget = MarkdownView("- first item")
    val buf = NewBuffer(20, 1)
    RenderTo(widget, Rect(X = 0, Y = 0, Width = 20, Height = 1), buf)
    return Eq(t, buf.CharAt(1, 0), '•')
}

// ----------------------------------------------------------------------------
// Width-aware: MarkdownLineCountAt + MarkdownViewAt
//
// The width-blind `MarkdownView` renders every paragraph in 1 row, so a
// long paragraph clips to its first wrapped line. The width-aware
// variant wraps paragraphs at the given width and reports an honest
// row count callers can use to allocate space.
// ----------------------------------------------------------------------------

func TestMarkdownLineCountShortParagraphIsOne(t T) T =
    Eq(t, MarkdownLineCountAt("hello world", 80), 1)

func TestMarkdownLineCountLongParagraphWraps(t T) T {
    val n = MarkdownLineCountAt("the quick brown fox jumps over the lazy dog twice", 20)
    return IsTrue(t, n > 1)
}

func TestMarkdownLineCountHeadingIsOne(t T) T =
    Eq(t, MarkdownLineCountAt("# Title", 80), 1)

func TestMarkdownLineCountCodeBlockIsLinesPlusBorder(t T) T {
    val src = "```gala\nval x = 1\nval y = 2\n```"
    return Eq(t, MarkdownLineCountAt(src, 80), 5)   // title + 2 lines + 2 border
}

func TestMarkdownLineCountSumsBlocks(t T) T {
    val src = "# Title\n\nA paragraph.\n\n- bullet one\n- bullet two\n"
    // heading(1) + blank(1) + paragraph(1) + blank(1) + bullet(1) + bullet(1) = 6
    return Eq(t, MarkdownLineCountAt(src, 80), 6)
}

func TestMarkdownLineCountMultiLineParagraphSummed(t T) T {
    val src = "Hello.\n\n" +
              "the quick brown fox jumps over the lazy dog twice"
    // "Hello." (1) + blank (1) + wrapped paragraph at width 20.
    val wrapped = WrapParagraph("the quick brown fox jumps over the lazy dog twice", 20)
    val expected = 1 + 1 + wrapped.Length()
    return Eq(t, MarkdownLineCountAt(src, 20), expected)
}

func TestMarkdownViewAtRendersWrappedParagraph(t T) T {
    val src = "the quick brown fox jumps over the lazy dog twice"
    val w = MarkdownViewAt(src, 20)
    val n = MarkdownLineCountAt(src, 20)
    val rows = SnapshotLines(w, 20, n)
    // Last visible row matches the last wrapped line.
    val wrapped = WrapParagraph(src, 20)
    return Eq(t, mdTrim(rows.Get(n - 1)), wrapped.Get(wrapped.Length() - 1))
}

func TestMarkdownViewAtBlanksBetweenParagraphs(t T) T {
    val src = "First.\n\nSecond."
    val w = MarkdownViewAt(src, 20)
    val rows = SnapshotLines(w, 20, 3)
    val t1 = Eq(t, mdTrim(rows.Get(0)), "First.")
    val t2 = Eq(t1, mdTrim(rows.Get(1)), "")
    return Eq(t2, mdTrim(rows.Get(2)), "Second.")
}

func TestMarkdownViewAtRendersHeadingAtAnyWidth(t T) T {
    val w = MarkdownViewAt("# Big Title", 80)
    val rows = SnapshotLines(w, 80, 1)
    return IsTrue(t, RuneCount(mdTrim(rows.Get(0))) >= RuneCount("Big Title"))
}

// IntrinsicHeightAt round-trip: the width-aware Markdown view's
// intrinsic height equals MarkdownLineCountAt for the same width.
func TestMarkdownViewAtIntrinsicHeightMatchesLineCount(t T) T {
    val src = "# Title\n\nA somewhat long paragraph that should wrap when " +
              "rendered into a narrow column of cells.\n\n- bullet one\n"
    val w = MarkdownViewAt(src, 30)
    val n = MarkdownLineCountAt(src, 30)
    return Eq(t, IntrinsicHeightAt(w, 30), n)
}

func mdTrim(s string) string {
    var end = RuneCount(s)
    for end > 0 {
        var i = 0
        var r = rune(0)
        for _, c := range s {
            if i == end - 1 { r = c; i = end }
            else { i = i + 1 }
        }
        if r != ' ' {
            var out = ""
            var j = 0
            for _, c := range s {
                if j < end { out = out + string(c) }
                j = j + 1
            }
            return out
        }
        end = end - 1
    }
    return ""
}

// ----------------------------------------------------------------------------
// Helpers
// ----------------------------------------------------------------------------

func blocksOfKind(blocks Array[MdBlock], kind string) int {
    var count = 0
    var i = 0
    val n = blocks.Length()
    for i < n {
        val matched = blocks.Get(i) match {
            case MdHeading(_, _)        => kind == "heading"
            case MdParagraph(_)         => kind == "paragraph"
            case MdBullet(_)            => kind == "bullet"
            case MdNumbered(_, _)       => kind == "numbered"
            case MdCodeBlock(_, _)      => kind == "code"
            case MdRule()               => kind == "rule"
            case MdBlank()              => kind == "blank"
        }
        if matched { count = count + 1 }
        i = i + 1
    }
    return count
}

func anyInlineOfKind(inlines Array[MdInline], kind string) bool {
    var i = 0
    val n = inlines.Length()
    for i < n {
        val matches = inlines.Get(i) match {
            case MdText(_)      => kind == "text"
            case MdBold(_)      => kind == "bold"
            case MdItalic(_)    => kind == "italic"
            case MdCode(_)      => kind == "code"
            case MdLink(_, _)   => kind == "link"
        }
        if matches { return true }
        i = i + 1
    }
    return false
}

func allInlinesText(inlines Array[MdInline]) bool {
    var i = 0
    val n = inlines.Length()
    for i < n {
        val isText = inlines.Get(i) match {
            case MdText(_) => true
            case _         => false
        }
        if !isText { return false }
        i = i + 1
    }
    return true
}
